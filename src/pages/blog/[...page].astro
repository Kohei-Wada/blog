---
import type { GetStaticPaths } from 'astro';
import BlogListLayout from '../../layouts/BlogListLayout.astro';
import { SITE_TITLE, POSTS_PER_PAGE } from '../../consts';
import { t } from '../../i18n/strings';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../../utils/content-aggregation';
import { getPostLang } from '../../utils/post-locale';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('blog');
  const posts = sortPostsByDate(all.filter(p => getPostLang(p.id) === 'en'));
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BlogListLayout
  title={SITE_TITLE}
  description={t('siteDescription', 'en')}
  posts={page.data}
  headerTitle="All Posts"
  headerIcon="📚"
  headerDescription="All English posts on this blog."
  page={page}
  baseUrl="/blog/"
/>
