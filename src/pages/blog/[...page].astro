---
import type { GetStaticPaths } from 'astro';
import BlogListLayout from '../../layouts/BlogListLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, POSTS_PER_PAGE } from '../../consts';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BlogListLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  posts={page.data}
  headerTitle="全ての記事"
  headerIcon="📚"
  headerDescription="技術記事から個人的な学びまで、これまでに書いた記事をすべてご覧いただけます。気になる記事があれば、ぜひクリックして詳細をお読みください。"
  page={page}
  baseUrl="/blog/"
/>
