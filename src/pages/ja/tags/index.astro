---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ManCommand from '../../../components/shared/ui/ManCommand.astro';
import { SITE_TITLE } from '../../../consts';
import { t } from '../../../i18n/strings';
import { getCollection } from 'astro:content';
import { getTagCounts, getAllTags } from '../../../utils/content-aggregation';
import { getPostLang } from '../../../utils/post-locale';

const all = await getCollection('blog');
const posts = all.filter(p => getPostLang(p.id) === 'ja');
const tagCounts = getTagCounts(posts);
const tags = getAllTags(posts);
const title = `タグ一覧 - ${SITE_TITLE}`;
---

<BaseLayout title={title} description={t('siteDescription', 'ja')}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{title}</p>
  </section>

  <section class="man-section">
    <h2>ALL TAGS</h2>
    <ManCommand cmd="ls -l tags/" />
    <ul class="ls-listing ls-listing--compact">
      {
        tags.map(tag => (
          <li>
            <span class="perms">drwxr-xr-x</span>
            <span class="size">{tagCounts[tag]}</span>
            <span class="title">
              <a href={`/ja/tags/${tag}/`}>{tag}</a>
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <p>
      <a href="/ja/blog">blog</a> · <a href="/ja/tags/">tags</a> · <a href="/ja/archives/"
        >archives</a
      >
    </p>
  </section>
</BaseLayout>
