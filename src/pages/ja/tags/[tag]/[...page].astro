---
import type { GetStaticPaths } from 'astro';
import BlogListLayout from '../../../../layouts/BlogListLayout.astro';
import { SITE_TITLE, POSTS_PER_PAGE } from '../../../../consts';
import { t } from '../../../../i18n/strings';
import { getCollection } from 'astro:content';
import { getAllTags, getPostsByTag, sortPostsByDate } from '../../../../utils/content-aggregation';
import { getPostLang } from '../../../../utils/post-locale';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('blog');
  const posts = all.filter(p => getPostLang(p.id) === 'ja');
  const tags = getAllTags(posts);

  return tags.flatMap(tag => {
    const tagPosts = sortPostsByDate(getPostsByTag(posts, tag));
    return paginate(tagPosts, {
      params: { tag },
      pageSize: POSTS_PER_PAGE,
    });
  });
}) satisfies GetStaticPaths;

const { tag } = Astro.params;
if (!tag) {
  throw new Error('Tag parameter is required');
}

const { page } = Astro.props;
const title = `${tag} - ${SITE_TITLE}`;
const description = t('siteDescription', 'ja');
---

<BlogListLayout
  title={title}
  description={description}
  posts={page.data}
  sectionLabel="APROPOS"
  command={`ls -l tags/${tag}/`}
  siblingHref="/"
  page={page}
  baseUrl={`/tags/${tag}/`}
/>
