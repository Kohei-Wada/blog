---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, HOME_TITLE, GITHUB_URL, ZENN_URL, QIITA_URL, X_URL } from '../../consts';
import { t } from '../../i18n/strings';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../../utils/content-aggregation';
import PostsList from '../../components/blog/content/PostsList.astro';
import ManCommand from '../../components/shared/ui/ManCommand.astro';
import { getPostLang } from '../../utils/post-locale';

const all = await getCollection('blog');
const allPosts = all.filter(p => getPostLang(p.id) === 'ja');
const posts = sortPostsByDate(allPosts).slice(0, 10);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.status === 'active')
  .sort((a, b) => {
    if (b.data.order !== a.data.order) return b.data.order - a.data.order;
    return a.data.name.localeCompare(b.data.name);
  })
  .slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={t('siteDescription', 'ja')}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{HOME_TITLE} -- {t('siteSubtitle', 'ja')}</p>
  </section>

  <section class="man-section">
    <h2>SYNOPSIS</h2>
    <p>
      <a href={GITHUB_URL}>GitHub</a> ·
      <a href={ZENN_URL}>Zenn</a> ·
      <a href={QIITA_URL}>Qiita</a> ·
      <a href={X_URL}>X</a>
    </p>
  </section>

  <section class="man-section">
    <h2>DESCRIPTION</h2>
    <p>{t('siteDescription', 'ja')}</p>
    <p>
      Notes on building tools (taskdog, ttymap, knowledge-gardener) and what I learned along the
      way. Bilingual: 日本語 / English.
    </p>
  </section>

  <section class="man-section">
    <h2>RECENT</h2>
    <ManCommand cmd="ls -lt blog/ | head -n 10" />
    <PostsList posts={posts} />
  </section>

  <section class="man-section">
    <h2>PROJECTS</h2>
    <ul class="projects">
      {
        featuredProjects.map(p => (
          <li>
            <a href={p.data.repo}>{p.data.name}</a> — {p.data.description}
          </li>
        ))
      }
    </ul>
    <p class="see-all">
      <span class="man-prompt"></span><a href="/ja/projects">ls --all → /projects</a>
    </p>
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <p>
      <a href="/ja/blog">blog</a> · <a href="/ja/tags/">tags</a> · <a href="/ja/archives/"
        >archives</a
      > · <a href="/">en</a>
    </p>
  </section>

  <section class="man-section">
    <h2>SEE ALSO</h2>
    <p>
      <a href={GITHUB_URL}>github(1)</a>,
      <a href={ZENN_URL}>zenn(1)</a>,
      <a href={QIITA_URL}>qiita(1)</a>,
      <a href={X_URL}>x(1)</a>
    </p>
  </section>
</BaseLayout>
