---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

const all = await getCollection('projects');
const sorted = all.sort((a, b) => {
  if (b.data.order !== a.data.order) return b.data.order - a.data.order;
  return a.data.name.localeCompare(b.data.name);
});

const groups = [
  { id: 'active', label: 'ACTIVE', items: sorted.filter(p => p.data.status === 'active') },
  {
    id: 'maintenance',
    label: 'MAINTENANCE',
    items: sorted.filter(p => p.data.status === 'maintenance'),
  },
  { id: 'archived', label: 'ARCHIVED', items: sorted.filter(p => p.data.status === 'archived') },
];

// Resolve related-post slugs to title/href so missing slugs fail loudly at build.
async function resolveRelated(slugs: string[]): Promise<Array<{ title: string; href: string }>> {
  const resolved = await Promise.all(
    slugs.map(async slug => {
      const post = await getEntry('blog', `ja/${slug}`);
      if (!post) {
        throw new Error(
          `project relatedPosts entry "${slug}" did not resolve under blog/ja/. ` +
            `Either add the post or remove the slug.`
        );
      }
      return { title: post.data.title, href: `/blog/${slug}` };
    })
  );
  return resolved;
}

const groupsWithRelated = await Promise.all(
  groups.map(async group => ({
    ...group,
    items: await Promise.all(
      group.items.map(async item => ({
        ...item,
        related: await resolveRelated(item.data.relatedPosts),
      }))
    ),
  }))
);
---

<BaseLayout
  title="Projects — wada-dev"
  description="OSS 作品のショーケース。各プロジェクトの概要、技術スタック、リポジトリ、関連記事を一覧。"
>
  <section class="man-section">
    <h2>NAME</h2>
    <p>projects — OSS 作品ショーケース</p>
  </section>

  <section class="man-section">
    <h2>DESCRIPTION</h2>
    <p>
      自作の OSS
      作品を一覧します。各プロジェクトの概要、使用技術、リポジトリへのリンク、関連する制作過程記事をまとめています。
    </p>
  </section>

  {
    groupsWithRelated.map(
      group =>
        group.items.length > 0 && (
          <section class="man-section">
            <h2>{group.label}</h2>
            <ul class="projects">
              {group.items.map(item => (
                <li class="project">
                  <div class="project-head">
                    <a class="project-name" href={item.data.repo}>
                      {item.data.name}
                    </a>
                    <span class="project-stack">
                      {item.data.stack.map((s, i) => (
                        <>
                          <span class="tag-pill">{s}</span>
                          {i < item.data.stack.length - 1 && <span class="dot"> · </span>}
                        </>
                      ))}
                    </span>
                  </div>
                  <p class="project-desc">{item.data.description}</p>
                  <p class="project-meta">
                    <span class="man-prompt" />
                    <a href={item.data.repo}>{item.data.repo.replace(/^https?:\/\//, '')}</a>
                  </p>
                  {item.related.length > 0 && (
                    <p class="project-related">
                      <span class="label">↪ related: </span>
                      {item.related.map((r, i) => (
                        <>
                          <a href={r.href}>{r.title}</a>
                          {i < item.related.length - 1 && <span> · </span>}
                        </>
                      ))}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )
    )
  }

  <section class="man-section">
    <h2>SEE ALSO</h2>
    <p>
      <a href="https://github.com/Kohei-Wada">github(1)</a>, <a href="/blog">blog(7)</a>
    </p>
  </section>

  <style>
    .projects {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .project {
      padding: 0.75em 0;
      border-bottom: 1px dashed var(--border);
    }
    .project:last-child {
      border-bottom: 0;
    }
    .project-head {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 1ch;
    }
    .project-name {
      font-weight: bold;
      color: var(--accent);
      text-decoration: none;
    }
    .project-name:hover {
      text-decoration: underline;
    }
    .project-stack {
      font-size: var(--font-size-sm);
    }
    .project-stack .dot {
      color: var(--text-dim);
    }
    .project-desc {
      margin: 0.25em 0;
    }
    .project-meta {
      margin: 0;
      font-size: var(--font-size-sm);
      color: var(--text-dim);
    }
    .project-meta a {
      color: var(--text-dim);
      text-decoration: underline;
    }
    .project-meta a:hover {
      color: var(--accent);
    }
    .project-related {
      margin: 0.25em 0 0;
      font-size: var(--font-size-sm);
    }
    .project-related .label {
      color: var(--text-dim);
    }
  </style>
</BaseLayout>
