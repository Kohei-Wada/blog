---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');
const sorted = all.sort((a, b) => {
  if (b.data.order !== a.data.order) return b.data.order - a.data.order;
  return a.data.name.localeCompare(b.data.name);
});

const groups = [
  { id: 'active', label: 'ACTIVE', items: sorted.filter(p => p.data.status === 'active') },
  {
    id: 'maintenance',
    label: 'MAINTENANCE',
    items: sorted.filter(p => p.data.status === 'maintenance'),
  },
  { id: 'archived', label: 'ARCHIVED', items: sorted.filter(p => p.data.status === 'archived') },
];
---

<BaseLayout
  title="Projects — wada-dev"
  description="A showcase of my OSS work. Each project lists what it is, its stack, repo link, and related posts."
>
  <section class="man-section">
    <h2>NAME</h2>
    <p>projects — OSS showcase</p>
  </section>

  <section class="man-section">
    <h2>DESCRIPTION</h2>
    <p>
      A list of my open-source projects. Each entry includes the description, stack, repository
      link, and related write-ups (English versions added as they ship).
    </p>
  </section>

  {
    groups.map(
      group =>
        group.items.length > 0 && (
          <section class="man-section">
            <h2>{group.label}</h2>
            <ul class="projects">
              {group.items.map(item => (
                <li class="project">
                  <div class="project-head">
                    <a class="project-name" href={item.data.repo}>
                      {item.data.name}
                    </a>
                    <span class="project-stack">
                      {item.data.stack.map((s, i) => (
                        <>
                          <span class="tag-pill">{s}</span>
                          {i < item.data.stack.length - 1 && <span class="dot"> · </span>}
                        </>
                      ))}
                    </span>
                  </div>
                  <p class="project-desc">{item.data.description_en}</p>
                  <p class="project-meta">
                    <span class="man-prompt" />
                    <a href={item.data.repo}>{item.data.repo.replace(/^https?:\/\//, '')}</a>
                  </p>
                </li>
              ))}
            </ul>
          </section>
        )
    )
  }

  <section class="man-section">
    <h2>SEE ALSO</h2>
    <p>
      <a href="https://github.com/Kohei-Wada">github(1)</a>, <a href="/blog">blog(7)</a>
    </p>
  </section>

  <style>
    .projects {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .project {
      padding: 0.75em 0;
      border-bottom: 1px dashed var(--border);
    }
    .project:last-child {
      border-bottom: 0;
    }
    .project-head {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 1ch;
    }
    .project-name {
      font-weight: bold;
      color: var(--accent);
      text-decoration: none;
    }
    .project-name:hover {
      text-decoration: underline;
    }
    .project-stack {
      font-size: var(--font-size-sm);
    }
    .project-stack .dot {
      color: var(--text-dim);
    }
    .project-desc {
      margin: 0.25em 0;
    }
    .project-meta {
      margin: 0;
      font-size: var(--font-size-sm);
      color: var(--text-dim);
    }
    .project-meta a {
      color: var(--text-dim);
      text-decoration: underline;
    }
    .project-meta a:hover {
      color: var(--accent);
    }
  </style>
</BaseLayout>
