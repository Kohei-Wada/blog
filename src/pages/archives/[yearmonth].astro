---
import BlogListLayout from '../../layouts/BlogListLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { groupPostsByMonth, parseArchiveSlug, formatArchiveLabel } from '../../utils/archive-utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const archives = groupPostsByMonth(posts);

  return archives.map(archive => ({
    params: { yearmonth: archive.slug },
    props: { archive },
  }));
}

const { archive } = Astro.props;
const { yearmonth: yearMonthParam } = Astro.params;

// URLパラメータから年月を取得
const parsed = parseArchiveSlug(yearMonthParam);
if (!parsed) {
  return Astro.redirect('/404');
}

const { year, month } = parsed;
const title = `${formatArchiveLabel(year, month)} - ${SITE_TITLE}`;
const description = `${formatArchiveLabel(year, month)}に投稿された記事一覧です。`;
---

<BlogListLayout
  title={title}
  description={description}
  posts={archive.posts}
  headerTitle={formatArchiveLabel(year, month)}
  headerIcon="📅"
  headerDescription={`${formatArchiveLabel(year, month)}に投稿された記事の一覧です。${archive.count}件の記事があります。`}
  withBottomMargin={false}
/>
