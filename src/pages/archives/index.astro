---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { groupPostsByMonth } from '../../utils/archive-utils';
import { getPostLang } from '../../utils/post-locale';

const all = await getCollection('blog');
const posts = all.filter(p => getPostLang(p.id) === 'ja');
const archives = groupPostsByMonth(posts);
const title = `アーカイブ - ${SITE_TITLE}`;
const description = 'ブログ記事の月別アーカイブ一覧です。';

const groupedByYear = new Map<number, typeof archives>();
archives.forEach(archive => {
  if (!groupedByYear.has(archive.year)) {
    groupedByYear.set(archive.year, []);
  }
  groupedByYear.get(archive.year)!.push(archive);
});

const sortedYears = Array.from(groupedByYear.keys()).sort((a, b) => b - a);
---

<BaseLayout title={title} description={description}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{title}</p>
  </section>

  <section class="man-section">
    <h2>BY YEAR</h2>
    {
      archives.length === 0 ? (
        <p>まだ記事が投稿されていません。</p>
      ) : (
        sortedYears.map(year => (
          <div class="archive-year-group">
            <h3>{year}年</h3>
            <ul class="ls-listing ls-listing--compact">
              {groupedByYear.get(year)!.map(archive => (
                <li>
                  <span class="perms">drwxr-xr-x</span>
                  <span class="size">{archive.count}</span>
                  <span class="title">
                    <a href={`/archives/${archive.slug}/`}>{archive.month}月</a>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      )
    }
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <p>
      <a href="/blog">blog</a> · <a href="/tags/">tags</a> · <a href="/archives/">archives</a>
    </p>
  </section>
</BaseLayout>
