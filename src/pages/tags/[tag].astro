---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import PageHeader from '../../components/PageHeader.astro';
import PostsGrid from '../../components/PostsGrid.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = Array.from(new Set(posts.flatMap(post => post.data.tags))).sort();
  return tags.map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.params;
const posts = (await getCollection('blog'))
  .filter(post => post.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const title = `${tag} - ${SITE_TITLE}`;
const description = SITE_DESCRIPTION;
---

<BaseLayout title={title} description={description} showSidebar={true}>
  <div class="page-container with-bottom-margin">
    <PageHeader
      title={`${tag}タグの記事`}
      icon="🏷️"
      description={`${tag}に関する記事一覧です。${posts.length}件の記事があります。気になる記事があれば、ぜひクリックして詳細をお読みください。`}
    />
    <PostsGrid posts={posts} currentTag={tag} />
  </div>
</BaseLayout>
