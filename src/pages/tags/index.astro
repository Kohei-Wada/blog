---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import PageHeader from '../../components/shared/layout/PageHeader.astro';
import { getTagCounts, getTagsSortedByCount } from '../../utils/content-aggregation';
import { getPostLang } from '../../utils/post-locale';

const all = await getCollection('blog');
const posts = all.filter(p => getPostLang(p.id) === 'ja');
const tagCounts = getTagCounts(posts);
const tags = getTagsSortedByCount(posts);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} showSidebar={true}>
  <style>
    .tags-container {
      padding-bottom: var(--spacing-xl);
    }

    .tags-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: var(--spacing-sm);
      justify-content: center;
      margin-top: var(--spacing-md);
    }

    .tag-with-count {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .tag-count {
      font-size: 0.9em;
      opacity: 0.8;
    }
  </style>

  <div class="page-container">
    <PageHeader
      title="タグ一覧"
      icon="🏷️"
      description="記事をタグで分類して探すことができます。気になるタグをクリックして、関連記事をお楽しみください。"
    />
    <div class="tags-container">
      <div class="tags-cloud">
        {
          tags.map(tag => (
            <a href={`/tags/${tag}/`} class="tag solid">
              <span class="tag-with-count">
                {tag}
                <span class="tag-count">({tagCounts[tag]})</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
