---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
const tags = Array.from(new Set(posts.flatMap(post => post.data.tags))).sort();

const tagCounts: Record<string, number> = {};
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  });
});
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} showSidebar={true}>
  <style>
    .content {
      max-width: var(--content-max-width);
      margin: 0 auto;
      width: 100%;
      padding: 0 1rem;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 2rem;
      text-align: center;
      color: rgb(var(--black));
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }

    .title-icon {
      font-size: 2.2rem;
      filter: drop-shadow(0 2px 4px rgba(var(--accent), 0.3));
    }

    .page-description {
      text-align: center;
      color: rgb(var(--gray));
      font-size: 1.1rem;
      line-height: 1.6;
      margin-bottom: 3rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .index_tag_nav {
      padding-bottom: 100px;
    }

    .index_tag_nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 1.2rem;
      text-align: center;
    }

    .index_tag_nav ul li {
      display: inline-block;
      vertical-align: top;
      margin: 0 2px 4px;
    }

    .index_tag_nav ul li a {
      display: block;
      background-color: #fff;
      padding: 10px 15px;
      border-radius: 4px;
      color: rgb(var(--black));
      text-decoration: none;
      transition:
        background-color 0.2s ease,
        color 0.2s ease;
    }

    .index_tag_nav ul li a:hover {
      background-color: var(--accent);
      color: #fff;
    }

    .index_tag_nav ul li a h4 {
      margin: 0;
    }
  </style>

  <div class="content">
    <h1>
      <span class="title-icon">🏷️</span>
      タグ一覧
    </h1>
    <p class="page-description">
      記事をタグで分類して探すことができます。
      気になるタグをクリックして、関連記事をお楽しみください。
    </p>
    <div class="index_tag_nav">
      <ul>
        {
          tags.map(tag => (
            <li>
              <a href={`/tags/${tag}/`}>
                <h4>
                  {tag} ({tagCounts[tag]})
                </h4>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</BaseLayout>
