---
import type { GetStaticPaths } from 'astro';
import BlogListLayout from '../../../layouts/BlogListLayout.astro';
import { SITE_TITLE, POSTS_PER_PAGE } from '../../../consts';
import { t, type Locale } from '../../../i18n/strings';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../../../utils/content-aggregation';
import { getPostLang } from '../../../utils/post-locale';
import { LOCALES } from '../../../utils/i18n';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('blog');
  return LOCALES.flatMap(lang => {
    const posts = sortPostsByDate(all.filter(p => getPostLang(p.id) === lang));
    return paginate(posts, { params: { lang }, pageSize: POSTS_PER_PAGE });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const lang = Astro.params.lang as Locale;
---

<BlogListLayout
  title={SITE_TITLE}
  description={t('siteDescription', lang)}
  posts={page.data}
  command="ls -l blog/"
  page={page}
  baseUrl={`/${lang}/blog/`}
/>
