---
import type { GetStaticPaths } from 'astro';
import BlogListLayout from '../../../../layouts/BlogListLayout.astro';
import { SITE_TITLE, POSTS_PER_PAGE } from '../../../../consts';
import { type Locale } from '../../../../i18n/strings';
import { getCollection } from 'astro:content';
import {
  groupPostsByMonth,
  parseArchiveSlug,
  formatArchiveLabel,
} from '../../../../utils/archive-utils';
import { getPostLang } from '../../../../utils/post-locale';
import { LOCALES, otherLocale } from '../../../../utils/i18n';

export const getStaticPaths = (async ({ paginate }) => {
  const all = await getCollection('blog');
  return LOCALES.flatMap(lang => {
    const posts = all.filter(p => getPostLang(p.id) === lang);
    return groupPostsByMonth(posts).flatMap(archive =>
      paginate(archive.posts, {
        params: { lang, yearmonth: archive.slug },
        pageSize: POSTS_PER_PAGE,
      })
    );
  });
}) satisfies GetStaticPaths;

const lang = Astro.params.lang as Locale;
const { yearmonth: yearMonthParam } = Astro.params;
if (!yearMonthParam) {
  throw new Error('Year-month parameter is required');
}

const parsed = parseArchiveSlug(yearMonthParam);
if (!parsed) {
  throw new Error(`Invalid year-month format: ${yearMonthParam}`);
}

const { page } = Astro.props;
const { year, month } = parsed;
const label = formatArchiveLabel(year, month);
const title = `${label} - ${SITE_TITLE}`;
const description =
  lang === 'ja' ? `${label}に投稿された記事一覧です。` : `Posts published in ${label}.`;
---

<BlogListLayout
  title={title}
  description={description}
  posts={page.data}
  sectionLabel="LISTING"
  command={`ls -l archives/${yearMonthParam}/`}
  siblingHref={`/${otherLocale(lang)}/`}
  page={page}
  baseUrl={`/${lang}/archives/${yearMonthParam}/`}
/>
