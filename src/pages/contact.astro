---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GOOGLE_FORMS_URL } from '../consts';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout
  title="Contact - Kohei Wada"
  description="お問い合わせフォーム。ご質問やご連絡はこちらからどうぞ。"
  showSidebar={true}
>
  <style>
    .contact-container {
      margin-bottom: var(--spacing-xl);
    }

    .contact-iframe {
      width: 100%;
      height: 650px;
      border: none;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      background: var(--color-bg);
    }

    .loading-message {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 400px;
      color: var(--color-text-secondary);
      font-size: var(--font-size-lg);
    }

    @media (max-width: var(--tablet-breakpoint)) {
      .contact-iframe {
        height: 550px;
      }
    }

    @media (max-width: var(--mobile-breakpoint)) {
      .contact-iframe {
        height: 500px;
        border-radius: var(--radius-md);
      }
    }
  </style>

  <div class="page-container">
    <PageHeader
      title="お問い合わせ"
      icon="📧"
      description="ご質問、フィードバック、お仕事のご依頼など、お気軽にお声をおかけください。"
    />

    <div class="contact-container">
      <iframe
        src={GOOGLE_FORMS_URL}
        class="contact-iframe"
        title="お問い合わせフォーム"
        loading="lazy"
        allow="forms"
        aria-label="Google Forms お問い合わせフォーム"
      >
        Loading contact form...
      </iframe>
    </div>
  </div>
</BaseLayout>
