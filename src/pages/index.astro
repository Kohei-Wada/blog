---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_TITLE,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  SITE_HERO_DESCRIPTION,
  GITHUB_URL,
  ZENN_URL,
} from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import GitHubIcon from '../components/GitHubIcon.astro';
import { Image } from 'astro:assets';

// Featured Posts: featuredフラグがtrueの記事を優先、その後は日付順
const featuredPosts = (await getCollection('blog')).filter(post => post.data.featured);
const otherPosts = (await getCollection('blog')).filter(post => !post.data.featured);
const posts = [...featuredPosts, ...otherPosts]
  .sort((a, b) => {
    // featuredが優先、同じfeatured状態なら日付順
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} showSidebar={true}>
  <style>
    .content {
      max-width: var(--content-max-width);
      margin: 0 auto;
      width: 100%;
      padding: 0 1rem;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 4rem 0;
      border-bottom: 1px solid rgba(var(--accent-light), 0.1);
      margin-bottom: 3rem;
    }

    .hero-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 0 auto 2rem;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: bold;
      color: white;
      border: 4px solid rgba(var(--accent), 0.2);
    }

    .hero h1 {
      font-size: 2.5rem;
      margin: 0 0 0.5rem;
      color: var(--accent);
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* フォールバック：グラデーションがサポートされていない場合 */
    @supports not (-webkit-background-clip: text) {
      .hero h1 {
        color: var(--accent);
        background: none;
      }
    }

    .hero .subtitle {
      font-size: 1.3rem;
      color: var(--accent);
      margin: 0 0 1rem;
      font-weight: 600;
    }

    .hero .description {
      font-size: 1.1rem;
      color: rgb(var(--gray));
      margin: 0 0 2.5rem;
      line-height: 1.6;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .btn {
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: var(--accent-dark);
      transform: translateY(-2px);
    }

    .btn-secondary {
      background: transparent;
      color: var(--accent);
      border: 2px solid var(--accent);
    }

    .btn-secondary:hover {
      background: var(--accent);
      color: white;
      transform: translateY(-2px);
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
    }

    .social-link {
      color: rgb(var(--gray));
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      font-size: 0.9rem;
    }

    .social-link:hover {
      color: var(--accent);
      transform: translateY(-2px);
    }

    /* Featured Posts Section */
    .featured-posts {
      margin-top: 3rem;
      margin-bottom: 4rem;
    }

    .featured-posts h2 {
      font-size: 2rem;
      margin-bottom: 2rem;
      text-align: center;
      color: rgb(var(--black));
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .post-card {
      background: rgb(var(--gray-light));
      border-radius: 12px;
      overflow: hidden;
      transition: all 0.3s ease;
      border: 1px solid rgba(var(--accent-light), 0.1);
      max-height: 400px;
      display: flex;
      flex-direction: column;
    }

    .post-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px rgba(var(--accent), 0.1);
      border-color: var(--accent);
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .post-image {
      width: 100%;
      height: 150px;
      object-fit: cover;
      display: block;
    }

    .post-content {
      padding: 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .post-meta {
      color: var(--accent);
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .featured-badge {
      background: var(--accent);
      color: white;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
    }

    .post-card h3 {
      font-size: 1.2rem;
      margin: 0 0 0.8rem;
      line-height: 1.3;
      color: rgb(var(--black));
      flex-grow: 1;
    }

    .post-description {
      color: rgb(var(--gray));
      line-height: 1.5;
      margin-bottom: 1rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      font-size: 0.9rem;
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: auto;
    }

    .tag {
      background: rgba(var(--accent), 0.1);
      color: var(--accent);
      padding: 0.3rem 0.8rem;
      border-radius: 15px;
      font-size: 0.8rem;
      font-weight: 500;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        padding: 2rem 0;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .hero-avatar {
        width: 100px;
        height: 100px;
        font-size: 2.5rem;
      }

      .hero-buttons {
        flex-direction: column;
        align-items: center;
      }

      .posts-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .post-content {
        padding: 1rem;
      }

      .post-image {
        height: 120px;
      }

      .post-card {
        max-height: 320px;
      }

      .post-card h3 {
        font-size: 1.1rem;
        margin-bottom: 0.6rem;
      }

      .post-description {
        font-size: 0.85rem;
        margin-bottom: 0.8rem;
      }

      .featured-posts {
        margin-bottom: 3rem;
      }
    }
  </style>

  <div class="content">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-avatar">KW</div>
      <h1>{SITE_TITLE}</h1>
      <p class="subtitle">{SITE_SUBTITLE}</p>
      <p class="description">{SITE_HERO_DESCRIPTION}</p>

      <div class="hero-buttons">
        <a href="/blog/" class="btn btn-primary"> 📖 ブログを読む </a>
        <a href="#featured-posts" class="btn btn-secondary"> ⭐ おすすめ記事 </a>
      </div>

      <div class="social-links">
        <a href={GITHUB_URL} class="social-link" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          GitHub
        </a>
        <a href={ZENN_URL} class="social-link" target="_blank" rel="noopener noreferrer">
          📝 Zenn
        </a>
      </div>
    </section>

    <!-- Featured Posts Section -->
    <section class="featured-posts" id="featured-posts">
      <h2>おすすめ記事</h2>
      <div class="posts-grid">
        {
          posts.map(post => (
            <article class="post-card">
              <a href={`/blog/${post.id}/`}>
                {post.data.heroImage && (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    width={400}
                    height={200}
                    class="post-image"
                  />
                )}
                <div class="post-content">
                  <div class="post-meta">
                    <FormattedDate date={post.data.pubDate} />
                    {post.data.featured && <span class="featured-badge">おすすめ</span>}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p class="post-description">{post.data.description}</p>
                  <div class="post-tags">
                    {post.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
