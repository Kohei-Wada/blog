---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_TITLE,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  SITE_HERO_DESCRIPTION,
  GITHUB_URL,
  ZENN_URL,
} from '../consts';
import { getCollection } from 'astro:content';
import PostsGrid from '../components/PostsGrid.astro';
import HeroSection from '../components/HeroSection.astro';

// Featured Posts: featuredフラグがtrueの記事を優先、その後は日付順
const featuredPosts = (await getCollection('blog')).filter(post => post.data.featured);
const otherPosts = (await getCollection('blog')).filter(post => !post.data.featured);
const posts = [...featuredPosts, ...otherPosts]
  .sort((a, b) => {
    // featuredが優先、同じfeatured状態なら日付順
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} showSidebar={true}>
  <style>
    /* Featured Posts Section */
    .featured-posts {
      margin-top: var(--spacing-lg);
      margin-bottom: var(--spacing-xl);
    }

    .featured-posts h2 {
      font-size: var(--font-size-3xl);
      margin-bottom: var(--spacing-md);
      text-align: center;
      color: rgb(var(--black));
    }

    /* Responsive */
    @media (max-width: var(--tablet-breakpoint)) {
      .featured-posts {
        margin-bottom: var(--spacing-lg);
      }
    }
  </style>

  <div class="page-container">
    <!-- Hero Section -->
    <HeroSection
      title={SITE_TITLE}
      subtitle={SITE_SUBTITLE}
      description={SITE_HERO_DESCRIPTION}
      avatar="KW"
      buttons={[
        { text: '📖 ブログを読む', href: '/blog/', primary: true },
        { text: '⭐ おすすめ記事', href: '#featured-posts' },
      ]}
      socialLinks={[
        { text: 'GitHub', href: GITHUB_URL },
        { text: 'Zenn', href: ZENN_URL, icon: '📝' },
      ]}
    />

    <!-- Featured Posts Section -->
    <section class="featured-posts" id="featured-posts">
      <h2>おすすめ記事</h2>
      <PostsGrid posts={posts} />
    </section>
  </div>
</BaseLayout>
