---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, HOME_TITLE, GITHUB_URL, ZENN_URL, QIITA_URL, X_URL } from '../consts';
import { t } from '../i18n/strings';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../utils/content-aggregation';
import PostsList from '../components/blog/content/PostsList.astro';

const all = await getCollection('blog');
// English root surfaces every post regardless of locale so the site is not
// empty while English translations are filled in. Each row carries an
// (EN)/(JA) badge via PostsList showLang.
const featuredPosts = all.filter(post => post.data.featured);
const otherPosts = all.filter(post => !post.data.featured);
const posts = [...sortPostsByDate(featuredPosts), ...sortPostsByDate(otherPosts)].slice(0, 10);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.status === 'active')
  .sort((a, b) => {
    if (b.data.order !== a.data.order) return b.data.order - a.data.order;
    return a.data.name.localeCompare(b.data.name);
  })
  .slice(0, 3);

const description = t('siteDescription', 'en');
---

<BaseLayout title={SITE_TITLE} description={description}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{HOME_TITLE} -- {t('siteSubtitle', 'en')}</p>
  </section>

  <section class="man-section">
    <h2>SYNOPSIS</h2>
    <p>
      <a href={GITHUB_URL}>GitHub</a> ·
      <a href={ZENN_URL}>Zenn</a> ·
      <a href={QIITA_URL}>Qiita</a> ·
      <a href={X_URL}>X</a>
    </p>
  </section>

  <section class="man-section">
    <h2>DESCRIPTION</h2>
    <p>{description}</p>
    <p>Bilingual blog: English by default, 日本語 versions linked via the [en | ja] switcher.</p>
  </section>

  <section class="man-section">
    <h2>RECENT</h2>
    <PostsList posts={posts} showLang />
  </section>

  <section class="man-section">
    <h2>PROJECTS</h2>
    <ul class="projects">
      {
        featuredProjects.map(p => (
          <li>
            <a href={p.data.repo}>{p.data.name}</a> — {p.data.description_en}
          </li>
        ))
      }
    </ul>
    <p class="see-all">
      <span class="man-prompt"></span><a href="/projects">ls --all → /projects</a>
    </p>
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <p>
      <a href="/blog">blog</a> · <a href="/tags/">tags</a> · <a href="/archives/">archives</a> · <a
        href="/ja/">ja</a
      >
    </p>
  </section>

  <section class="man-section">
    <h2>SEE ALSO</h2>
    <p>
      <a href={GITHUB_URL}>github(1)</a>,
      <a href={ZENN_URL}>zenn(1)</a>,
      <a href={QIITA_URL}>qiita(1)</a>,
      <a href={X_URL}>x(1)</a>
    </p>
  </section>
</BaseLayout>
