---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_TITLE,
  HOME_TITLE,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  GITHUB_URL,
  ZENN_URL,
  QIITA_URL,
  X_URL,
} from '../consts';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../utils/content-aggregation';
import PostsList from '../components/blog/content/PostsList.astro';
import { getPostLang } from '../utils/post-locale';

const all = await getCollection('blog');
const allPosts = all.filter(p => getPostLang(p.id) === 'ja');
const featuredPosts = allPosts.filter(post => post.data.featured);
const otherPosts = allPosts.filter(post => !post.data.featured);
const posts = [...sortPostsByDate(featuredPosts), ...sortPostsByDate(otherPosts)].slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{HOME_TITLE} -- {SITE_SUBTITLE}</p>
  </section>

  <section class="man-section">
    <h2>SYNOPSIS</h2>
    <p>ソフトウェア開発、技術記事、そして個人的な学びについて発信しています。</p>
    <p>
      <a href={GITHUB_URL}>GitHub</a> ·
      <a href={ZENN_URL}>Zenn</a> ·
      <a href={QIITA_URL}>Qiita</a> ·
      <a href={X_URL}>X</a>
    </p>
  </section>

  <section class="man-section">
    <h2>RECENT</h2>
    <PostsList posts={posts} />
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <p>
      <a href="/blog">blog</a> · <a href="/tags/">tags</a> · <a href="/archives/">archives</a> · <a
        href="/en/">en</a
      >
    </p>
  </section>
</BaseLayout>
