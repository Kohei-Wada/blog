---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  SITE_TITLE,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  SITE_HERO_DESCRIPTION,
  GITHUB_URL,
  ZENN_URL,
} from '../consts';
import { getCollection } from 'astro:content';
import GitHubIcon from '../components/GitHubIcon.astro';
import PostCard from '../components/PostCard.astro';

// Featured Posts: featuredフラグがtrueの記事を優先、その後は日付順
const featuredPosts = (await getCollection('blog')).filter(post => post.data.featured);
const otherPosts = (await getCollection('blog')).filter(post => !post.data.featured);
const posts = [...featuredPosts, ...otherPosts]
  .sort((a, b) => {
    // featuredが優先、同じfeatured状態なら日付順
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} showSidebar={true}>
  <style>
    .content {
      max-width: var(--content-max-width);
      margin: 0 auto;
      width: 100%;
      padding: 0 1rem;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 4rem 0;
      border-bottom: 1px solid rgba(var(--accent-light), 0.1);
      margin-bottom: 3rem;
    }

    .hero-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 0 auto 2rem;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: bold;
      color: white;
      border: 4px solid rgba(var(--accent), 0.2);
    }

    .hero h1 {
      font-size: 2.5rem;
      margin: 0 0 0.5rem;
      color: var(--accent);
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* フォールバック：グラデーションがサポートされていない場合 */
    @supports not (-webkit-background-clip: text) {
      .hero h1 {
        color: var(--accent);
        background: none;
      }
    }

    .hero .subtitle {
      font-size: 1.3rem;
      color: var(--accent);
      margin: 0 0 1rem;
      font-weight: 600;
    }

    .hero .description {
      font-size: 1.1rem;
      color: rgb(var(--gray));
      margin: 0 0 2.5rem;
      line-height: 1.6;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .btn {
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: var(--accent-dark);
      transform: translateY(-2px);
    }

    .btn-secondary {
      background: transparent;
      color: var(--accent);
      border: 2px solid var(--accent);
    }

    .btn-secondary:hover {
      background: var(--accent);
      color: white;
      transform: translateY(-2px);
    }

    .social-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
    }

    .social-link {
      color: rgb(var(--gray));
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      font-size: 0.9rem;
    }

    .social-link:hover {
      color: var(--accent);
      transform: translateY(-2px);
    }

    /* Featured Posts Section */
    .featured-posts {
      margin-top: 3rem;
      margin-bottom: 4rem;
    }

    .featured-posts h2 {
      font-size: 2rem;
      margin-bottom: 2rem;
      text-align: center;
      color: rgb(var(--black));
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        padding: 2rem 0;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .hero-avatar {
        width: 100px;
        height: 100px;
        font-size: 2.5rem;
      }

      .hero-buttons {
        flex-direction: column;
        align-items: center;
      }

      .posts-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .featured-posts {
        margin-bottom: 3rem;
      }
    }
  </style>

  <div class="content">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-avatar">KW</div>
      <h1>{SITE_TITLE}</h1>
      <p class="subtitle">{SITE_SUBTITLE}</p>
      <p class="description">{SITE_HERO_DESCRIPTION}</p>

      <div class="hero-buttons">
        <a href="/blog/" class="btn btn-primary"> 📖 ブログを読む </a>
        <a href="#featured-posts" class="btn btn-secondary"> ⭐ おすすめ記事 </a>
      </div>

      <div class="social-links">
        <a href={GITHUB_URL} class="social-link" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          GitHub
        </a>
        <a href={ZENN_URL} class="social-link" target="_blank" rel="noopener noreferrer">
          📝 Zenn
        </a>
      </div>
    </section>

    <!-- Featured Posts Section -->
    <section class="featured-posts" id="featured-posts">
      <h2>おすすめ記事</h2>
      <div class="posts-grid">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    </section>
  </div>
</BaseLayout>
