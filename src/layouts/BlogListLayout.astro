---
import type { CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import BaseLayout from './BaseLayout.astro';
import PostsList from '../components/blog/content/PostsList.astro';
import Pagination from '../components/shared/ui/Pagination.astro';
import ManCommand from '../components/shared/ui/ManCommand.astro';
import { localeFromUrl } from '../utils/i18n';
import { buildListingCommand } from '../utils/listing-command';

interface Props {
  title: string;
  description: string;
  posts: CollectionEntry<'blog'>[];
  sectionLabel?: string;
  command?: string;
  siblingHref?: string;
  page?: Page<CollectionEntry<'blog'>>;
  baseUrl?: string;
}

const {
  title,
  description,
  posts,
  sectionLabel = 'LISTING',
  command,
  siblingHref,
  page,
  baseUrl = '/blog/',
} = Astro.props;

const locale = localeFromUrl(Astro.url);
const displayCommand = command && page ? buildListingCommand(command, page) : command;
---

<BaseLayout title={title} description={description} siblingHref={siblingHref}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{title}</p>
  </section>

  <section class="man-section">
    <h2>{sectionLabel}</h2>
    {displayCommand && <ManCommand cmd={displayCommand} />}
    <PostsList posts={posts} />
    {
      page && (
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
          baseUrl={baseUrl}
        />
      )
    }
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <slot name="navigation">
      <p>
        <a href={`/${locale}/blog`}>blog</a> · <a href={`/${locale}/tags/`}>tags</a> ·
        <a href={`/${locale}/archives/`}>archives</a>
      </p>
    </slot>
  </section>

  <slot />
</BaseLayout>
