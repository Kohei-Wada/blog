---
import type { CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import BaseLayout from './BaseLayout.astro';
import PostsList from '../components/blog/content/PostsList.astro';
import Pagination from '../components/shared/ui/Pagination.astro';

interface Props {
  title: string;
  description: string;
  posts: CollectionEntry<'blog'>[];
  sectionLabel?: string;
  siblingHref?: string;
  page?: Page<CollectionEntry<'blog'>>;
  baseUrl?: string;
  // legacy props kept for call-site compat (ignored)
  headerTitle?: string;
  headerIcon?: string;
  headerDescription?: string;
  currentTag?: string;
  withBottomMargin?: boolean;
}

const {
  title,
  description,
  posts,
  sectionLabel = 'LISTING',
  siblingHref,
  page,
  baseUrl = '/blog/',
} = Astro.props;
---

<BaseLayout title={title} description={description} siblingHref={siblingHref}>
  <section class="man-section">
    <h2>NAME</h2>
    <p>{title}</p>
  </section>

  <section class="man-section">
    <h2>{sectionLabel}</h2>
    <PostsList posts={posts} />
    {
      page && (
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
          baseUrl={baseUrl}
        />
      )
    }
  </section>

  <section class="man-section">
    <h2>NAVIGATION</h2>
    <slot name="navigation">
      <p>
        <a href="/blog">blog</a> · <a href="/tags/">tags</a> · <a href="/archives/">archives</a>
      </p>
    </slot>
  </section>

  <slot />
</BaseLayout>
