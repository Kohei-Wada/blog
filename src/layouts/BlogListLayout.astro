---
import type { CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/shared/layout/PageHeader.astro';
import PostsGrid from '../components/blog/content/PostsGrid.astro';
import Pagination from '../components/shared/ui/Pagination.astro';

interface Props {
  title: string;
  description: string;
  posts: CollectionEntry<'blog'>[];
  headerTitle: string;
  headerIcon?: string;
  headerDescription?: string;
  currentTag?: string;
  withBottomMargin?: boolean;
  page?: Page<CollectionEntry<'blog'>>;
  baseUrl?: string;
}

const {
  title,
  description,
  posts,
  headerTitle,
  headerIcon,
  headerDescription,
  currentTag,
  withBottomMargin = true,
  page,
  baseUrl = '/blog/',
} = Astro.props;

const containerClass = withBottomMargin ? 'page-container with-bottom-margin' : 'page-container';
---

<BaseLayout title={title} description={description} showSidebar={true}>
  <div class={containerClass}>
    <PageHeader title={headerTitle} icon={headerIcon} description={headerDescription} />
    <PostsGrid posts={posts} currentTag={currentTag} />
    {
      page && (
        <Pagination
          currentPage={page.currentPage}
          lastPage={page.lastPage}
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
          baseUrl={baseUrl}
        />
      )
    }
  </div>
</BaseLayout>
