---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: any;
  tags?: string[];
  headings?: import('../types/index.js').MarkdownHeading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  headings = [],
} = Astro.props;

// 現在のページのURLを取得
const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  isArticle={true}
  publishedTime={pubDate}
  showSidebar={true}
>
  <style>
    article {
      width: 100%;
    }
    .hero-image {
      width: 100%;
      margin-bottom: 2rem;
    }
    .hero-image img {
      display: block;
      margin: 0 auto;
      border-radius: 12px;
      box-shadow: var(--box-shadow);
      width: 100%;
      height: auto;
    }
    .prose {
      width: 100%;
      margin: 0;
      padding: 0;
      color: rgb(var(--gray-dark));
    }
    .title {
      margin-bottom: 1em;
      padding: 1em 0;
      text-align: center;
      line-height: 1;
    }
    .title h1 {
      margin: 0 0 0.5em 0;
    }
    .date {
      margin-bottom: 0.5em;
      color: rgb(var(--gray));
    }
    .last-updated-on {
      font-style: bold;
    }

    .published-on {
      font-style: bold;
    }
  </style>

  <div class="page-container">
    <article>
      <div class="hero-image">
        {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
      </div>
      <div class="prose">
        <div class="title">
          <div class="date">
            {
              pubDate && (
                <div class="published-on">
                  Published on:
                  <FormattedDate date={pubDate} />
                </div>
              )
            }

            {
              updatedDate && (
                <div class="last-updated-on">
                  Updated on : <FormattedDate date={updatedDate} />
                </div>
              )
            }
          </div>
          <h1>{title}</h1>
          <hr />
        </div>

        {
          tags.length > 0 && (
            <div class="tag-list center">
              {tags.map((tag: string) => (
                <a href={`/tags/${tag}/`} class="tag blog-post">
                  {tag}
                </a>
              ))}
            </div>
          )
        }

        <TableOfContents headings={headings} />

        <slot />
        <ShareButtons title={title} description={description} url={currentUrl} />
      </div>
    </article>
  </div>
</BaseLayout>
