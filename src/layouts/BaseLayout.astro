---
import '../styles/base/variables.css';
import '../styles/base/reset.css';
import '../styles/base/typography.css';
import '../styles/base/responsive.css';
import '../styles/components.css';
import '../styles/components/man-page.css';

import BaseHead from '../components/shared/layout/BaseHead.astro';
import LangSwitcher from '../components/shared/LangSwitcher.astro';
import GlobalNav from '../components/shared/GlobalNav.astro';
import SearchModal from '../components/shared/ui/SearchModal.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  isArticle?: boolean;
  publishedTime?: Date;
  showSidebar?: boolean; // back-compat: ignored by the new design
  siblingHref?: string;
}

const { title, description, image, isArticle, publishedTime, siblingHref } = Astro.props;
const pathname = Astro.url.pathname;
const sectionName = 'WADA-DEV(7)';
const today = new Date().toISOString().slice(0, 10);
const headerPath = pathname === '/' || pathname === '/ja/' ? '/' : pathname;
const localePrefix = pathname.startsWith('/ja') ? '/ja' : '';
---

<!doctype html>
<html lang={pathname.startsWith('/ja') ? 'ja' : 'en'}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      isArticle={isArticle}
      publishedTime={publishedTime}
    />
  </head>
  <body>
    <header class="man-header">
      <span class="hdr-section">{sectionName}</span>
      <span class="hdr-prompt">$ {headerPath}</span>
      <LangSwitcher siblingHref={siblingHref} />
    </header>
    <GlobalNav />
    <hr class="man-rule" />
    <main class="man-page">
      <slot />
    </main>
    <hr class="man-rule" />
    <footer class="man-footer">
      <span>{sectionName}</span>
      <nav class="man-footer-links" aria-label="footer">
        <a href={`${localePrefix}/contact`}>contact</a>
        <a href={`${localePrefix}/privacy`}>privacy</a>
      </nav>
      <span>{today}</span>
    </footer>
    <SearchModal />

    <style>
      .man-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1ch;
        max-width: var(--max-content);
        margin: 1.5em auto 0;
        padding: 0 1rem;
        color: var(--text-dim);
        font-size: var(--font-size-base);
      }
      .hdr-section {
        font-weight: bold;
        color: var(--text);
        letter-spacing: 0.08em;
        white-space: nowrap;
      }
      /* The path can be arbitrarily long (e.g. /blog/<long-slug>); keep the
         header on one line by truncating it instead of crowding the
         LangSwitcher off the edge. */
      .hdr-prompt {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
      }
      .man-header :global(.lang-switcher) {
        flex: 0 0 auto;
        white-space: nowrap;
      }
    </style>
  </body>
</html>
