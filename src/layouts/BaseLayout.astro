---
import BaseHead from '../components/shared/layout/BaseHead.astro';
import Header from '../components/shared/layout/Header.astro';
import Footer from '../components/shared/layout/Footer.astro';
import Sidebar from '../components/blog/navigation/Sidebar.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  isArticle?: boolean;
  publishedTime?: Date;
  showSidebar?: boolean;
}

const { title, description, image, isArticle, publishedTime, showSidebar = false } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      isArticle={isArticle}
      publishedTime={publishedTime}
    />
  </head>
  <body>
    <Header />
    <div class={showSidebar ? 'layout-with-sidebar' : 'layout-single'}>
      {showSidebar && <div class="spacer-left" />}
      <main class={showSidebar ? 'main-with-sidebar' : ''}>
        <slot />
      </main>
      {showSidebar && <div class="gap-spacer" />}
      {showSidebar && <Sidebar />}
    </div>
    <Footer />
  </body>
</html>
