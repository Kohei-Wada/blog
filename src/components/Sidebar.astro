---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import GitHubActivity from './GitHubActivity.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allPosts = await getCollection('blog');
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))].sort();

const tagCounts = allTags.reduce(
  (acc, tag) => {
    acc[tag] = allPosts.filter(post => post.data.tags.includes(tag)).length;
    return acc;
  },
  {} as Record<string, number>
);
---

<aside class="sidebar">
  <section class="sidebar-section">
    <h3>最近の投稿</h3>
    <ul class="recent-posts">
      {
        posts.map(post => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <h4>{post.data.title}</h4>
              <p class="post-date">
                <FormattedDate date={post.data.pubDate} />
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="sidebar-section">
    <h3>タグ</h3>
    <div class="tag-cloud tag-list">
      {
        allTags.map(tag => (
          <a href={`/tags/${tag}/`} class="tag solid" data-count={tagCounts[tag]}>
            {tag} ({tagCounts[tag]})
          </a>
        ))
      }
    </div>
  </section>

  <GitHubActivity />
</aside>

<style>
  .sidebar {
    width: 100%;
    padding: 0 1rem;
  }

  .sidebar-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--card-background);
    border-radius: 8px;
  }

  .sidebar-section h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2em;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-link);
    padding-bottom: 0.5rem;
  }

  .recent-posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .recent-posts li {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: var(--separator-border);
  }

  .recent-posts li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .recent-posts a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .recent-posts a:hover {
    color: var(--color-link);
  }

  .recent-posts h4 {
    margin: 0 0 0.25rem 0;
    font-size: 0.9em;
    line-height: 1.3;
  }

  .post-date {
    margin: 0;
    font-size: 0.8em;
    color: var(--color-text-secondary);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
