    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        var args = Array.prototype.slice.call(arguments);
        window.dataLayer.push(args);
      }
      gtag('js', new Date());
      gtag('config', 'G-XGH4QVLSMS');
    </script>
  </>
)}
