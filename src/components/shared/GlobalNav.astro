---
import { localeFromUrl } from '../../utils/i18n';

const locale = localeFromUrl(Astro.url);
const prefix = locale === 'en' ? '/en' : '';
const stripped = Astro.url.pathname.replace(/^\/en/, '') || '/';

let current: string | null = null;
if (stripped === '/' || stripped === '') current = 'home';
else if (stripped.startsWith('/blog')) current = 'blog';
else if (stripped.startsWith('/tags')) current = 'tags';
else if (stripped.startsWith('/archives')) current = 'archives';
else if (stripped.startsWith('/projects')) current = 'projects';
else if (stripped.startsWith('/about')) current = 'about';

const links: Array<{ id: string; label: string; href: string }> = [
  { id: 'home', label: 'home', href: `${prefix}/` },
  { id: 'blog', label: 'blog', href: `${prefix}/blog` },
  { id: 'tags', label: 'tags', href: `${prefix}/tags/` },
  { id: 'archives', label: 'archives', href: `${prefix}/archives/` },
  { id: 'projects', label: 'projects', href: `${prefix}/projects` },
  { id: 'about', label: 'about', href: `${prefix}/about` },
];
---

<nav class="global-nav" aria-label="primary">
  {
    links.map(link =>
      link.id === current ? (
        <span class="active" aria-current="page">
          {link.label}
        </span>
      ) : (
        <a href={link.href}>{link.label}</a>
      )
    )
  }
  <button
    type="button"
    class="global-nav-search"
    data-search-trigger
    aria-label="Open search (press / or Ctrl+K)"
    title="Open search (/ or Ctrl+K)"
  >
    <span class="global-nav-search-prompt" aria-hidden="true">$ man -k</span>
    <span class="global-nav-search-hint" aria-hidden="true">
      <kbd>/</kbd>
      <span class="global-nav-search-hint-sep">·</span>
      <kbd>Ctrl</kbd>+<kbd>K</kbd>
    </span>
  </button>
</nav>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('[data-search-trigger]');
  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('search-modal:open'));
    });
  });
</script>

<style>
  .global-nav {
    display: flex;
    flex-wrap: wrap;
    column-gap: 2ch;
    row-gap: 0.15em;
    max-width: var(--max-content);
    margin: 0.25em auto 0;
    padding: 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--text-dim);
  }
  .global-nav a {
    color: var(--text-dim);
    text-decoration: none;
  }
  .global-nav a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .global-nav .active {
    color: var(--text);
    font-weight: bold;
  }
  .global-nav-search {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 1ch;
    background: transparent;
    border: 1px dashed var(--border);
    color: var(--text-dim);
    font: inherit;
    cursor: pointer;
    padding: 0 0.5ch;
  }
  .global-nav-search:hover,
  .global-nav-search:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    outline: none;
  }
  .global-nav-search-prompt {
    color: inherit;
  }
  .global-nav-search-hint {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25ch;
    color: var(--text-dim);
    font-size: var(--font-size-xs);
  }
  .global-nav-search-hint kbd {
    border: 1px solid var(--border);
    padding: 0 0.4ch;
    font-family: inherit;
    font-size: var(--font-size-xs);
    color: var(--text-dim);
    background: var(--bg-alt);
  }
  .global-nav-search-hint-sep {
    opacity: 0.6;
  }
  @media (max-width: 600px) {
    .global-nav {
      padding: 0 0.75rem;
    }
    .global-nav-search-hint {
      display: none;
    }
  }
</style>
