---
import { localeFromUrl } from '../../utils/i18n';

const locale = localeFromUrl(Astro.url);
const prefix = locale === 'ja' ? '/ja' : '';
const stripped = Astro.url.pathname.replace(/^\/ja/, '') || '/';

let current: string | null = null;
if (stripped === '/' || stripped === '') current = 'home';
else if (stripped.startsWith('/blog')) current = 'blog';
else if (stripped.startsWith('/tags')) current = 'tags';
else if (stripped.startsWith('/archives')) current = 'archives';
else if (stripped.startsWith('/projects')) current = 'projects';
else if (stripped.startsWith('/about')) current = 'about';

const links: Array<{ id: string; label: string; href: string }> = [
  { id: 'home', label: 'home', href: `${prefix}/` },
  { id: 'blog', label: 'blog', href: `${prefix}/blog` },
  { id: 'tags', label: 'tags', href: `${prefix}/tags/` },
  { id: 'archives', label: 'archives', href: `${prefix}/archives/` },
  { id: 'projects', label: 'projects', href: `${prefix}/projects` },
  { id: 'about', label: 'about', href: `${prefix}/about` },
];
---

<nav class="global-nav" aria-label="primary">
  <div class="nav-inline">
    {
      links.map(link =>
        link.id === current ? (
          <span class="active" aria-current="page">
            {link.label}
          </span>
        ) : (
          <a href={link.href}>{link.label}</a>
        )
      )
    }
    <button
      type="button"
      class="global-nav-search"
      data-search-trigger
      aria-label="Open search (press / or Ctrl+K)"
      title="Open search (/ or Ctrl+K)"
    >
      <span class="global-nav-search-prompt" aria-hidden="true">$ man -k</span>
      <span class="global-nav-search-hint" aria-hidden="true">
        <kbd>/</kbd>
        <span class="global-nav-search-hint-sep">·</span>
        <kbd>Ctrl</kbd>+<kbd>K</kbd>
      </span>
    </button>
  </div>

  <button
    type="button"
    class="nav-toggle"
    data-nav-toggle
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Menu"
  >
    <span class="nav-toggle-icon" aria-hidden="true">☰</span>
    <span class="nav-toggle-label">menu</span>
  </button>
</nav>

<div id="mobile-menu" class="mobile-menu" data-nav-menu hidden>
  <ul class="mobile-menu-list">
    {
      links.map(link => (
        <li>
          <a
            href={link.href}
            class={link.id === current ? 'active' : ''}
            aria-current={link.id === current ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))
    }
    <li>
      <button type="button" class="mobile-menu-search" data-search-trigger>
        <span aria-hidden="true">$ man -k</span> search
      </button>
    </li>
  </ul>
</div>

<script>
  const searchTriggers = document.querySelectorAll<HTMLButtonElement>('[data-search-trigger]');
  searchTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('search-modal:open'));
    });
  });

  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-nav-menu]');

  if (toggle && menu) {
    const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

    const open = () => {
      toggle.setAttribute('aria-expanded', 'true');
      menu.hidden = false;
    };
    const close = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    };

    toggle.addEventListener('click', () => {
      if (isOpen()) close();
      else open();
    });

    // Selecting a link or the search button closes the menu.
    menu.addEventListener('click', event => {
      const target = event.target as HTMLElement | null;
      if (target?.closest('a, button')) close();
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && isOpen()) {
        close();
        toggle.focus();
      }
    });

    document.addEventListener('click', event => {
      if (!isOpen()) return;
      const target = event.target as Node;
      if (!menu.contains(target) && !toggle.contains(target)) close();
    });

    // Collapse back to the inline nav if the viewport grows past mobile.
    window.matchMedia('(min-width: 601px)').addEventListener('change', e => {
      if (e.matches) close();
    });
  }
</script>

<style>
  .global-nav {
    max-width: var(--max-content);
    margin: 0.25em auto 0;
    padding: 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-base);
    color: var(--text-dim);
  }
  .nav-inline {
    display: flex;
    flex-wrap: wrap;
    column-gap: 2ch;
    row-gap: 0.15em;
    align-items: baseline;
  }
  .nav-inline a {
    color: var(--text-dim);
    text-decoration: none;
  }
  .nav-inline a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .nav-inline .active {
    color: var(--text);
    font-weight: bold;
  }
  .global-nav-search {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 1ch;
    background: transparent;
    border: 1px dashed var(--border);
    color: var(--text-dim);
    font: inherit;
    cursor: pointer;
    padding: 0 0.5ch;
  }
  .global-nav-search:hover,
  .global-nav-search:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    outline: none;
  }
  .global-nav-search-prompt {
    color: inherit;
  }
  .global-nav-search-hint {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25ch;
    color: var(--text-dim);
    font-size: var(--font-size-xs);
  }
  .global-nav-search-hint kbd {
    border: 1px solid var(--border);
    padding: 0 0.4ch;
    font-family: inherit;
    font-size: var(--font-size-xs);
    color: var(--text-dim);
    background: var(--bg-alt);
  }
  .global-nav-search-hint-sep {
    opacity: 0.6;
  }

  /* Hamburger toggle + dropdown are desktop-hidden; revealed ≤600px. */
  .nav-toggle {
    display: none;
  }
  .mobile-menu {
    display: none;
  }

  @media (max-width: 600px) {
    .nav-inline {
      display: none;
    }
    /* The nav bar becomes a single right-aligned hamburger row. */
    .global-nav {
      display: flex;
      justify-content: flex-end;
      padding: 0 0.75rem;
    }
    .nav-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.75ch;
      min-height: 44px;
      padding: 0 0.5ch;
      background: transparent;
      border: none;
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 1.15rem;
      cursor: pointer;
    }
    .nav-toggle-icon {
      font-size: 1.5rem;
      line-height: 1;
    }
    .nav-toggle[aria-expanded='true'] {
      color: var(--accent);
    }

    .mobile-menu {
      display: block;
      max-width: var(--max-content);
      margin: 0.25rem auto 0;
      padding: 0 0.75rem;
    }
    .mobile-menu[hidden] {
      display: none;
    }
    .mobile-menu-list {
      list-style: none;
      margin: 0;
      padding: 0;
      border-top: 1px dashed var(--border);
      font-family: var(--font-mono);
      font-size: 1.25rem;
    }
    .mobile-menu-list li {
      border-bottom: 1px dashed var(--border);
    }
    .mobile-menu-list a,
    .mobile-menu-search {
      display: flex;
      align-items: center;
      width: 100%;
      min-height: 48px;
      padding: 0 0.5ch;
      color: var(--text-dim);
      text-decoration: none;
      background: transparent;
      border: none;
      font: inherit;
      text-align: left;
      cursor: pointer;
    }
    .mobile-menu-list a:hover,
    .mobile-menu-list a.active {
      color: var(--accent);
    }
    .mobile-menu-list a.active {
      font-weight: bold;
    }
    .mobile-menu-search {
      gap: 1ch;
    }
    .mobile-menu-search span {
      color: var(--accent);
    }
  }
</style>
