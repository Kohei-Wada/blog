---

---

<div
  id="search-modal"
  class="search-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-modal-title"
  aria-hidden="true"
>
  <div class="search-overlay" data-search-close></div>
  <div class="search-shell" role="document">
    <h2 id="search-modal-title" class="visually-hidden">Search articles</h2>
    <header class="search-input-bar">
      <span class="search-prompt" aria-hidden="true">$ man -k</span>
      <input
        id="search-input"
        type="search"
        class="search-input"
        autocomplete="off"
        spellcheck="false"
        autocorrect="off"
        autocapitalize="off"
        aria-controls="search-results"
        aria-autocomplete="list"
        aria-activedescendant=""
      />
      <span class="search-input-cursor" aria-hidden="true">▌</span>
      <button type="button" class="search-close-button" data-search-close aria-label="Close search">
        <kbd>Esc</kbd>
      </button>
    </header>
    <div class="search-body">
      <ul id="search-results" class="search-results" role="listbox" aria-label="Search results">
      </ul>
      <aside id="search-preview" class="search-preview-pane" aria-live="polite"></aside>
    </div>
    <footer id="search-status" class="search-status" aria-live="polite"></footer>
  </div>
</div>

<script>
  import { UI_CONFIG } from '../../../constants/ui';
  import { createSearchIndex, search, type SearchItem } from '../../../utils/search';
  import {
    createInitialState,
    handleKeyboardNavigation,
    isSearchShortcut,
    renderPreviewHtml,
    renderRecentPostsHtml,
    renderResultListHtml,
    renderStatusBarHtml,
  } from '../../../utils/search-modal-controller';
  import { t } from '../../../i18n/strings';
  import type Fuse from 'fuse.js';

  type Mode = 'recent' | 'results';

  // The modal is a single global instance; pick labels + index by the
  // locale of the current page.
  const locale = window.location.pathname.startsWith('/ja') ? 'ja' : 'en';
  const noResultsLabel = t('searchNoResults', locale);
  const previewPromptLabel = t('searchPreviewPrompt', locale);

  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const resultsEl = document.getElementById('search-results');
  const previewEl = document.getElementById('search-preview');
  const statusEl = document.getElementById('search-status');

  if (modal && input && resultsEl && previewEl && statusEl) {
    const state = createInitialState();
    let mode: Mode = 'recent';
    let recentItems: SearchItem[] = [];
    let fuse: Fuse<SearchItem> | null = null;
    let indexLoadPromise: Promise<void> | null = null;
    let debounceHandle: number | undefined;
    let lastFocused: HTMLElement | null = null;

    async function loadIndex(): Promise<void> {
      if (fuse) return;
      if (!indexLoadPromise) {
        // Search the locale matching the current page: /ja/* searches the
        // Japanese index, everything else (English default) the root index.
        const indexUrl = window.location.pathname.startsWith('/ja')
          ? '/ja/search-index.json'
          : '/search-index.json';
        indexLoadPromise = fetch(indexUrl)
          .then(r => (r.ok ? (r.json() as Promise<SearchItem[]>) : Promise.reject(r.status)))
          .then(items => {
            recentItems = [...items].sort(
              (a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
            );
            fuse = createSearchIndex(items);
          })
          .catch(err => {
            console.error('[SearchModal] failed to load search index', err);
          });
      }
      await indexLoadPromise;
    }

    function currentItem(): SearchItem | null {
      if (mode === 'results') {
        const result = state.results[state.selectedIndex];
        return result ? result.item : null;
      }
      return recentItems[state.selectedIndex] ?? null;
    }

    function currentTotal(): number {
      return mode === 'results' ? state.results.length : recentItems.length;
    }

    function visibleTotal(): number {
      return Math.min(currentTotal(), UI_CONFIG.SEARCH_MAX_RESULTS);
    }

    function render(): void {
      const total = currentTotal();
      if (mode === 'results') {
        resultsEl!.innerHTML = renderResultListHtml(
          state.results,
          state.selectedIndex,
          input!.value,
          noResultsLabel
        );
      } else {
        resultsEl!.innerHTML = renderRecentPostsHtml(
          recentItems,
          state.selectedIndex,
          noResultsLabel
        );
      }
      previewEl!.innerHTML = renderPreviewHtml(currentItem(), previewPromptLabel);
      statusEl!.innerHTML = renderStatusBarHtml(state.selectedIndex, total);
      const id = currentItem() && visibleTotal() > 0 ? `search-result-${state.selectedIndex}` : '';
      input!.setAttribute('aria-activedescendant', id);
      const selectedRow = resultsEl!.querySelector<HTMLElement>('.is-selected');
      selectedRow?.scrollIntoView({ block: 'nearest' });
    }

    function setQuery(query: string): void {
      if (!query.trim()) {
        mode = 'recent';
        state.results = [];
      } else if (fuse) {
        mode = 'results';
        state.results = search(fuse, query);
      } else {
        mode = 'results';
        state.results = [];
      }
      state.selectedIndex = 0;
      render();
    }

    function open(): void {
      if (modal!.getAttribute('aria-hidden') === 'false') return;
      lastFocused = (document.activeElement as HTMLElement) ?? null;
      modal!.setAttribute('aria-hidden', 'false');
      document.body.classList.add('search-modal-open');
      loadIndex().then(() => {
        mode = 'recent';
        state.selectedIndex = 0;
        state.results = [];
        input!.value = '';
        render();
        input!.focus();
      });
    }

    function close(): void {
      if (modal!.getAttribute('aria-hidden') === 'true') return;
      modal!.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('search-modal-open');
      window.clearTimeout(debounceHandle);
      if (lastFocused && document.contains(lastFocused)) {
        lastFocused.focus();
      }
    }

    function focusableElements(): HTMLElement[] {
      return Array.from(
        modal!.querySelectorAll<HTMLElement>(
          'input, button, [href], [tabindex]:not([tabindex="-1"])'
        )
      ).filter(el => !el.hasAttribute('disabled') && el.offsetParent !== null);
    }

    function trapFocus(event: KeyboardEvent): void {
      if (event.key !== 'Tab') return;
      const elements = focusableElements();
      if (elements.length === 0) return;
      const first = elements[0];
      const last = elements[elements.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }

    function onModalKeyDown(event: KeyboardEvent): void {
      if (event.key === 'Escape') {
        event.preventDefault();
        close();
        return;
      }
      if (event.key === 'Tab') {
        trapFocus(event);
        return;
      }
      if (event.key === 'Enter') {
        const item = currentItem();
        if (item) {
          event.preventDefault();
          window.location.href = item.url;
        }
        return;
      }
      const before = state.selectedIndex;
      const after = handleKeyboardNavigation(event.key, event.ctrlKey, before, currentTotal());
      if (after !== before) {
        event.preventDefault();
        state.selectedIndex = after;
        render();
      }
    }

    input.addEventListener('input', () => {
      window.clearTimeout(debounceHandle);
      const value = input.value;
      debounceHandle = window.setTimeout(() => {
        setQuery(value);
      }, UI_CONFIG.SEARCH_DEBOUNCE_MS);
    });

    modal.addEventListener('keydown', onModalKeyDown);

    modal.addEventListener('click', event => {
      const target = event.target as HTMLElement | null;
      if (!target) return;
      if (target.closest('[data-search-close]')) {
        event.preventDefault();
        close();
        return;
      }
      const row = target.closest<HTMLElement>('.search-result-row');
      if (row) {
        const idx = Number(row.dataset.index);
        if (!Number.isNaN(idx)) {
          state.selectedIndex = idx;
          render();
        }
      }
    });

    resultsEl.addEventListener('mousemove', event => {
      const target = event.target as HTMLElement | null;
      const row = target?.closest<HTMLElement>('.search-result-row');
      if (!row) return;
      const idx = Number(row.dataset.index);
      if (Number.isNaN(idx) || idx === state.selectedIndex) return;
      state.selectedIndex = idx;
      render();
    });

    window.addEventListener('keydown', event => {
      if (modal.getAttribute('aria-hidden') === 'false') return;
      if (isSearchShortcut(event)) {
        event.preventDefault();
        open();
      }
    });

    window.addEventListener('search-modal:open', () => open());
  }
</script>

<style is:global>
  body.search-modal-open {
    overflow: hidden;
  }

  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1rem 1rem;
    font-family: var(--font-mono);
    color: var(--text);
  }
  .search-modal[aria-hidden='false'] {
    display: flex;
  }

  .search-overlay {
    position: absolute;
    inset: 0;
    background: rgba(244, 236, 216, 0.92);
    backdrop-filter: blur(2px);
  }

  .search-shell {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 960px;
    background: var(--bg);
    border: 1px solid var(--text);
    border-radius: 0;
    box-shadow: 4px 4px 0 var(--text-dim);
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 6rem);
  }

  .search-input-bar {
    display: flex;
    align-items: center;
    gap: 0.5ch;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .search-prompt {
    color: var(--accent);
    font-weight: bold;
    white-space: nowrap;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font: inherit;
    color: var(--text);
    padding: 0;
    min-width: 0;
  }

  .search-input::-webkit-search-cancel-button,
  .search-input::-webkit-search-decoration {
    appearance: none;
  }

  @keyframes search-cursor-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .search-input-cursor {
    color: var(--accent);
    animation: search-cursor-blink 1s steps(1) infinite;
    margin-left: -0.5ch;
  }

  .search-close-button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    color: var(--text-dim);
    font: inherit;
  }
  .search-close-button kbd {
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    padding: 0.05em 0.4em;
    font-family: inherit;
    font-size: var(--font-size-xs);
    color: var(--text-dim);
  }

  .search-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    min-height: 0;
    flex: 1;
  }

  .search-results {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    overflow-y: auto;
    border-right: 1px solid var(--border);
    min-height: 0;
  }

  .search-empty {
    padding: 1rem 1.25rem;
    color: var(--text-dim);
  }

  .search-result-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5ch;
    padding: 0.35rem 1rem;
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
    line-height: 1.4;
  }

  .search-result-row.is-selected {
    background: var(--bg-alt);
  }

  .search-result-prefix {
    color: var(--accent);
    font-weight: bold;
    width: 1ch;
    flex-shrink: 0;
  }

  .search-result-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }

  .search-result-title {
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-row.is-selected .search-result-title {
    color: var(--accent);
  }

  .search-result-meta {
    color: var(--text-dim);
    font-size: var(--font-size-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-title .match,
  .search-result-meta .match {
    color: var(--accent);
    font-weight: bold;
  }

  .search-preview-pane {
    padding: 1rem 1.25rem;
    overflow-y: auto;
    min-height: 0;
    background: var(--bg);
  }

  .search-preview-empty {
    color: var(--text-dim);
    padding: 0.5rem 0;
  }

  .search-preview-header {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .search-preview-title {
    font-size: var(--font-size-lg);
    margin: 0 0 0.25rem;
    color: var(--text);
    font-weight: bold;
  }

  .search-preview-date {
    margin: 0;
    color: var(--text-dim);
    font-size: var(--font-size-xs);
  }

  .search-preview-section {
    margin-bottom: 1rem;
  }

  .search-preview-section:last-child {
    margin-bottom: 0;
  }

  .search-preview-heading {
    margin: 0 0 0.25rem;
    font-size: var(--font-size-xs);
    font-weight: bold;
    color: var(--accent-2);
    letter-spacing: 0.1em;
  }

  .search-preview-description,
  .search-preview-excerpt {
    margin: 0;
    color: var(--text);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  .search-preview-excerpt {
    white-space: pre-wrap;
  }

  .search-preview-tags {
    margin: 0;
    color: var(--text);
    font-size: var(--font-size-sm);
  }

  .search-status {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg-alt);
    color: var(--text-dim);
    font-size: var(--font-size-xs);
  }

  .search-status kbd {
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    padding: 0.05em 0.4em;
    margin: 0 0.25ch;
    font-family: inherit;
    color: var(--text-dim);
  }

  .search-status-hints {
    display: flex;
    gap: 0.75rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .search-modal {
      padding: 0;
      align-items: stretch;
    }
    .search-shell {
      max-width: none;
      max-height: none;
      min-height: 100vh;
      border: none;
      box-shadow: none;
    }
    .search-body {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
    }
    .search-results {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .search-status-hints {
      gap: 0.5rem;
    }
  }
</style>
