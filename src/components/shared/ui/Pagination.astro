---
interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
  baseUrl: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props;

function getPageUrl(page: number): string {
  if (page === 1) {
    return baseUrl;
  }
  return `${baseUrl}${page}/`;
}

const showPagination = lastPage > 1;
const pages = Array.from({ length: lastPage }, (_, i) => i + 1);
---

{
  showPagination && (
    <nav class="pagination" aria-label="ページナビゲーション">
      <a
        href={prevUrl}
        class:list={['pagination-btn', 'prev', { disabled: !prevUrl }]}
        aria-disabled={!prevUrl}
      >
        &larr; 前へ
      </a>

      <div class="pagination-numbers">
        {pages.map(page => (
          <a
            href={getPageUrl(page)}
            class:list={['pagination-btn', { active: page === currentPage }]}
            aria-current={page === currentPage ? 'page' : undefined}
          >
            {page}
          </a>
        ))}
      </div>

      <a
        href={nextUrl}
        class:list={['pagination-btn', 'next', { disabled: !nextUrl }]}
        aria-disabled={!nextUrl}
      >
        次へ &rarr;
      </a>
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-lg) 0;
    padding: var(--spacing-md) 0;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--subtle-background);
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-weight: 500;
    transition: all var(--transition-normal);
  }

  .pagination-btn:hover:not(.disabled):not(.active) {
    background-color: var(--hover-background);
    color: var(--color-link);
    border-color: var(--color-link);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .pagination-btn:focus {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }

  .pagination-btn.active {
    background-color: var(--color-link);
    color: var(--color-bg);
    border-color: var(--color-link);
    font-weight: 600;
  }

  .pagination-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .pagination-btn.prev,
  .pagination-btn.next {
    font-weight: 600;
  }

  .pagination-numbers {
    display: flex;
    gap: var(--spacing-xs);
  }

  @media (max-width: 768px) {
    .pagination {
      margin: var(--spacing-md) 0;
      gap: var(--spacing-xs);
    }

    .pagination-btn {
      min-width: 40px;
      height: 40px;
      padding: var(--spacing-xs);
      font-size: var(--font-size-sm);
    }
  }

  @media (max-width: 480px) {
    .pagination {
      flex-wrap: wrap;
      gap: var(--spacing-xs);
    }

    .pagination-btn {
      min-width: 36px;
      height: 36px;
      padding: 4px;
    }

    .pagination-btn.prev,
    .pagination-btn.next {
      min-width: auto;
      padding: 4px var(--spacing-xs);
    }
  }
</style>
