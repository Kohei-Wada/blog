---
interface Props {
  currentPage: number;
  lastPage: number;
  prevUrl: string | undefined;
  nextUrl: string | undefined;
  baseUrl: string;
}

const { currentPage, lastPage, prevUrl, nextUrl, baseUrl } = Astro.props;

function getPageUrl(page: number): string {
  if (page === 1) {
    return baseUrl;
  }
  return `${baseUrl}${page}/`;
}

const showPagination = lastPage > 1;
const pages = Array.from({ length: lastPage }, (_, i) => i + 1);
---

{
  showPagination && (
    <nav class="pagination" aria-label="pagination">
      {prevUrl ? (
        <a href={prevUrl} class="arrow" rel="prev">
          &larr;
        </a>
      ) : (
        <span class="arrow disabled" aria-disabled="true">
          &larr;
        </span>
      )}
      {pages.map(page =>
        page === currentPage ? (
          <span class="page current" aria-current="page">
            [{page}]
          </span>
        ) : (
          <a href={getPageUrl(page)} class="page">
            {page}
          </a>
        )
      )}
      {nextUrl ? (
        <a href={nextUrl} class="arrow" rel="next">
          &rarr;
        </a>
      ) : (
        <span class="arrow disabled" aria-disabled="true">
          &rarr;
        </span>
      )}
    </nav>
  )
}

<style>
  .pagination {
    margin: 1.5em 0 0;
    font-family: var(--font-mono);
    color: var(--text);
    line-height: 1.8;
  }

  .pagination > * + * {
    margin-left: 1ch;
  }

  .page,
  .arrow {
    color: var(--text);
    text-decoration: none;
  }

  .page:hover,
  .arrow:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .current {
    font-weight: bold;
    color: var(--accent);
  }

  .disabled {
    color: var(--text-dim);
    cursor: not-allowed;
  }

  /* On narrow viewports, let it wrap onto two lines rather than overflow. */
  @media (max-width: 600px) {
    .pagination {
      display: flex;
      flex-wrap: wrap;
      row-gap: 0.25em;
    }
  }
</style>
