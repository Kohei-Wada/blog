---
/**
 * Calendar Icon (wrapper for backward compatibility)
 */
import Icon from './Icon.astro';

interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 16, height = 16, class: className = '' } = Astro.props;
---

<Icon name="calendar" width={width} height={height} class={className} />
