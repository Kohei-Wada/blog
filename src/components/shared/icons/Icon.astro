---
/**
 * Generic Icon Component
 * Centralized SVG icon management to reduce duplication
 */

type IconName = 'calendar' | 'update' | 'github' | 'x' | 'zenn' | 'facebook' | 'line' | 'linkedin';

interface Props {
  name: IconName;
  width?: number;
  height?: number;
  class?: string;
}

