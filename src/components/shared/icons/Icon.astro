const { name, width, height, class: className = '' } = Astro.props;
const icon = ICONS[name];
const size = width ?? height ?? icon.defaultSize;
const finalWidth = width ?? size;
const finalHeight = height ?? size;
---

{
  icon.type === 'stroke' ? (
    <svg
      viewBox={icon.viewBox}
      aria-hidden="true"
      width={finalWidth}
      height={finalHeight}
      class={className}
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      set:html={icon.content}
    />
  ) : (
    <svg
      viewBox={icon.viewBox}
      aria-hidden="true"
      width={finalWidth}
      height={finalHeight}
      class={className}
      set:html={icon.content}
    />
  )
}
