---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  avatar?: string;
  avatarImage?: ImageMetadata;
  buttons?: { text: string; href: string; primary?: boolean }[];
  socialLinks?: { text: string; href: string; icon?: string }[];
}

const {
  title,
  subtitle,
  description,
  avatar,
  avatarImage,
  buttons = [],
  socialLinks = [],
} = Astro.props;
---

<section class="hero">
  {
    avatarImage ? (
      <div class="hero-avatar hero-avatar-image">
        <Image src={avatarImage} alt="Blog icon" width={120} height={120} />
      </div>
    ) : (
      avatar && <div class="hero-avatar">{avatar}</div>
    )
  }
  <h1>{title}</h1>
  {subtitle && <p class="subtitle">{subtitle}</p>}
  {description && <p class="description">{description}</p>}

  {
    buttons.length > 0 && (
      <div class="hero-buttons">
        {buttons.map(button => (
          <a href={button.href} class={`btn ${button.primary ? 'btn-primary' : 'btn-secondary'}`}>
            {button.text}
          </a>
        ))}
      </div>
    )
  }

  {
    socialLinks.length > 0 && (
      <div class="social-links">
        {socialLinks.map(link => (
          <a href={link.href} class="social-link" target="_blank" rel="noopener noreferrer">
            {link.icon && link.icon}
            {link.text}
          </a>
        ))}
      </div>
    )
  }
</section>

<style>
  .hero {
    text-align: center;
    padding: var(--spacing-xl) 0;
    border-bottom: var(--separator-border);
    margin-bottom: var(--spacing-lg);
  }

  .hero-avatar {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-full);
    margin: 0 auto var(--spacing-md);
    background: linear-gradient(135deg, var(--color-link), var(--color-link-hover));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: bold;
    color: var(--color-bg);
    border: 4px solid var(--color-border);
    overflow: hidden;
  }

  .hero-avatar-image {
    background: none;
  }

  .hero-avatar-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero h1 {
    font-size: var(--font-size-4xl);
    margin: 0 0 var(--spacing-xs);
    color: var(--color-link);
    background: linear-gradient(135deg, var(--color-link), var(--color-link-hover));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* フォールバック：グラデーションがサポートされていない場合 */
  @supports not (-webkit-background-clip: text) {
    .hero h1 {
      color: var(--color-link);
      background: none;
    }
  }

  .hero .subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-link);
    margin: 0 0 var(--spacing-sm);
    font-weight: 600;
  }

  .hero .description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin: 0 0 2.5rem;
    line-height: 1.6;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-md);
  }

  /* Responsive */
  @media (max-width: var(--tablet-breakpoint)) {
    .hero {
      padding: var(--spacing-md) 0;
    }

    .hero h1 {
      font-size: var(--font-size-3xl);
    }

    .hero-avatar {
      width: 100px;
      height: 100px;
      font-size: 2.5rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
