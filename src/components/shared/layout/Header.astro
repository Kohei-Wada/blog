---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import { SITE_TITLE } from '../../../consts';
---

<header>
  <nav aria-label="Main navigation">
    <div class="nav-pills">
      <a href="/" class="site-title">{SITE_TITLE}</a>
      <span class="nav-divider"></span>
      <HeaderLink href="/">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 9l9-7 9 7v11a2 2 0 01-2 2h-4a2 2 0 01-2-2V12H9v8a2 2 0 01-2 2H3a2 2 0 01-2-2z"
          ></path>
        </svg>
        <span class="nav-text">Home</span>
      </HeaderLink>
      <HeaderLink href="/blog">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-7-7l7 7-7 7-7-7 7-7z"></path>
        </svg>
        <span class="nav-text">Blog</span>
      </HeaderLink>
      <HeaderLink href="/tags">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 7l10 10 4-4V7a2 2 0 00-2-2H9a2 2 0 00-2 2z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9h.01"></path>
        </svg>
        <span class="nav-text">Tags</span>
      </HeaderLink>
      <HeaderLink href="/about">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5.121 17.804A9 9 0 1118.88 6.196 9 9 0 015.12 17.804z"></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span class="nav-text">About</span>
      </HeaderLink>
      <HeaderLink href="/contact">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 8h18a2 2 0 002-2V8a2 2 0 00-2-2H3a2 2 0 00-2 2v6a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="nav-text">Contact</span>
      </HeaderLink>
      <span class="nav-divider"></span>
      <ThemeToggle />
    </div>
  </nav>
</header>
<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    margin: 0;
    width: 100%;
    padding: 0.75rem 0;
    pointer-events: none;
    transform: translateY(0);
    transition: transform 0.3s ease;
  }

  header.header-hidden {
    transform: translateY(-100%);
  }

  /* Spacer to prevent content jump when header hides */
  header::before {
    content: '';
    display: block;
    height: 0;
  }

  nav {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-pills {
    display: flex;
    align-items: center;
    background: var(--header-bg);
    border-radius: 9999px;
    padding: 0.25rem 0.5rem;
    gap: 0.25rem;
    box-shadow: var(--shadow-md);
    pointer-events: auto;
  }

  .site-title {
    display: inline-flex;
    align-items: center;
    padding: 0.5em 0.75em;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    border-radius: 9999px;
    transition: background var(--transition-fast);
  }

  .site-title:hover {
    background: var(--hover-background);
  }

  .nav-divider {
    width: 1px;
    height: 1.2em;
    background: var(--color-border);
    margin: 0 0.25rem;
  }

  .nav-pills a {
    display: inline-flex;
    align-items: center;
    padding: 0.5em 0.75em;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 9999px;
    transition: background var(--transition-fast);
  }

  .nav-pills a:hover {
    background: var(--hover-background);
  }

  .nav-pills a.active {
    background: var(--active-background);
    color: var(--color-link);
  }

  .nav-icon {
    width: 1em;
    height: 1em;
    margin-right: 0.25em;
  }

  /* Medium screens (641px-768px): compress content */
  @media (max-width: 768px) and (min-width: 641px) {
    .nav-pills a {
      padding: 0.5em 0.5em;
      font-size: 0.9em;
    }
    .site-title {
      padding: 0.5em 0.5em;
      font-size: 0.9em;
    }
  }

  /* Small screens (640px and below): icons only, hide text */
  @media (max-width: 640px) {
    .nav-pills {
      padding: 0.2rem 0.3rem;
    }
    .nav-pills a {
      padding: 0.5em 0.5em;
    }
    .site-title {
      padding: 0.5em 0.5em;
      font-size: 0.85em;
    }
    .nav-text {
      display: none;
    }
    .nav-icon {
      margin-right: 0;
      width: 1.2em;
      height: 1.2em;
    }
  }

  /* Extra small screens (480px and below): more compact */
  @media (max-width: 480px) {
    .nav-pills {
      padding: 0.15rem 0.25rem;
    }
    .nav-pills a {
      padding: 0.4em 0.4em;
    }
    .site-title {
      padding: 0.4em 0.4em;
      font-size: 0.8em;
    }
    .nav-icon {
      width: 1.1em;
      height: 1.1em;
    }
    .nav-divider {
      margin: 0 0.15rem;
    }
  }

  /* Tiny screens (380px and below): minimal padding */
  @media (max-width: 380px) {
    .nav-pills {
      padding: 0.1rem 0.2rem;
    }
    .nav-pills a {
      padding: 0.35em 0.35em;
    }
    .site-title {
      padding: 0.35em 0.35em;
      font-size: 0.75em;
    }
    .nav-icon {
      width: 1em;
      height: 1em;
    }
    .nav-divider {
      margin: 0 0.1rem;
    }
  }
</style>

<script>
  const header = document.querySelector('header');
  let lastScrollY = window.scrollY;
  let ticking = false;

  function updateHeader() {
    const currentScrollY = window.scrollY;

    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      // Scrolling down: hide header
      header?.classList.add('header-hidden');
    } else {
      // Scrolling up: show header
      header?.classList.remove('header-hidden');
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  function handleScroll() {
    if (!ticking) {
      requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }

  function cleanup() {
    window.removeEventListener('scroll', handleScroll);
  }

  window.addEventListener('scroll', handleScroll);

  // Cleanup on page unload or navigation
  window.addEventListener('beforeunload', cleanup);
  document.addEventListener('astro:before-preparation', cleanup);
</script>
