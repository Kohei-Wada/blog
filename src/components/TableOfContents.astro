---
import type { MarkdownHeading, TocItem } from '../types/index.js';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

function buildTocStructure(headings: MarkdownHeading[]): TocItem[] {
  const toc: TocItem[] = [];
  const stack: TocItem[] = [];

  for (const heading of headings) {
    // h1は除外（記事タイトルなので）
    if (heading.depth === 1) continue;

    const tocItem: TocItem = {
      ...heading,
      subheadings: [],
    };

    // スタックから現在の深度より深いものを削除
    while (stack.length > 0 && stack[stack.length - 1].depth >= heading.depth) {
      stack.pop();
    }

    if (stack.length === 0) {
      // ルートレベル（h2）
      toc.push(tocItem);
    } else {
      // 親見出しの子として追加
      stack[stack.length - 1].subheadings.push(tocItem);
    }

    stack.push(tocItem);
  }

  return toc;
}

const tocStructure = buildTocStructure(headings);

// TOCが表示すべき見出しがあるかチェック
const hasToc = tocStructure.length > 0;
---

{
  hasToc && (
    <nav class="table-of-contents">
      <details class="toc-details" open>
        <summary class="toc-summary" role="button" aria-label="目次の表示/非表示を切り替え">
          <span class="toc-title">目次</span>
          <span class="toc-toggle" aria-hidden="true">
            ▼
          </span>
        </summary>
        <ol class="toc-list">
          {tocStructure.map(item => (
            <li>
              <a href={`#${item.slug}`} class="toc-link">
                {item.text}
              </a>
              {item.subheadings.length > 0 && (
                <ol class="toc-sublist">
                  {item.subheadings.map(subItem => (
                    <li>
                      <a href={`#${subItem.slug}`} class="toc-sublink">
                        {subItem.text}
                      </a>
                    </li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </details>
    </nav>
  )
}

<style>
  .table-of-contents {
    background: var(--card-background);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: var(--card-border);
  }

  .toc-details {
    border: none;
    margin: 0;
    padding: 0;
  }

  .toc-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 1rem 0;
    padding: 0.75rem 0 0.5rem 0;
    border-bottom: 2px solid var(--color-link);
    transition: all 0.2s ease;
    user-select: none;
    outline: none;
  }

  .toc-summary:hover {
    color: var(--color-link);
  }

  .toc-summary::-webkit-details-marker {
    display: none;
  }

  .toc-title {
    font-size: 1.1em;
    color: var(--color-text);
    font-weight: 600;
  }

  .toc-toggle {
    font-size: 0.9em;
    color: var(--color-link);
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .toc-details:not([open]) .toc-toggle {
    transform: rotate(-90deg);
  }

  .toc-details[open] .toc-toggle {
    transform: rotate(0deg);
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: toc-counter;
  }

  .toc-list > li {
    counter-increment: toc-counter;
    margin-bottom: 0.75rem;
  }

  .toc-list > li:last-child {
    margin-bottom: 0;
  }

  .toc-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95em;
    line-height: 1.4;
    display: block;
    padding: 0.25rem 0;
    border-radius: 4px;
    transition: all 0.2s ease;
    position: relative;
  }

  .toc-link::before {
    content: counter(toc-counter) '. ';
    color: var(--color-link);
    font-weight: 700;
  }

  .toc-link:hover {
    color: var(--color-link);
    background: var(--active-background);
    padding-left: 0.5rem;
  }

  .toc-sublist {
    margin: 0.5rem 0 0 1.5rem;
    padding: 0;
    list-style: none;
    border-left: 2px solid var(--color-border);
    padding-left: 1rem;
  }

  .toc-sublist li {
    margin-bottom: 0.5rem;
  }

  .toc-sublist li:last-child {
    margin-bottom: 0;
  }

  .toc-sublink {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9em;
    line-height: 1.3;
    display: block;
    padding: 0.2rem 0;
    transition: all 0.2s ease;
    position: relative;
  }

  .toc-sublink::before {
    content: '• ';
    color: var(--color-link);
    font-weight: bold;
    margin-right: 0.25rem;
  }

  .toc-sublink:hover {
    color: var(--color-link);
    padding-left: 0.5rem;
  }

  /* モバイル対応 */
  @media (max-width: 768px) {
    .table-of-contents {
      margin: 1rem 0 2rem 0;
      padding: 1.25rem;
    }

    .toc-link {
      font-size: 0.9em;
    }

    .toc-sublink {
      font-size: 0.85em;
    }

    .toc-sublist {
      margin-left: 1rem;
      padding-left: 0.75rem;
    }
  }

  /* スムーズスクロール */
  html {
    scroll-behavior: smooth;
  }

  /* アンカーリンクのオフセット調整 */
  :target {
    scroll-margin-top: 2rem;
  }
</style>

<script>
  // TOC機能の初期化
  document.addEventListener('DOMContentLoaded', () => {
    const tocDetails = document.querySelector('.toc-details') as HTMLDetailsElement;
    const tocLinks = document.querySelectorAll('.toc-link, .toc-sublink');
    const headings = document.querySelectorAll('h2[id], h3[id]');

    if (!tocDetails) return;

    // localStorageから折り畳み状態を復元
    const storageKey = 'toc-collapsed';
    const isCollapsed = localStorage.getItem(storageKey) === 'true';

    // レスポンシブな初期状態設定
    const isMobile = window.innerWidth <= 768;
    const shouldBeCollapsed = isCollapsed || isMobile;

    if (shouldBeCollapsed) {
      tocDetails.removeAttribute('open');
    } else {
      tocDetails.setAttribute('open', '');
    }

    // 折り畳み状態の変更をlocalStorageに保存
    tocDetails.addEventListener('toggle', () => {
      localStorage.setItem(storageKey, (!tocDetails.open).toString());
    });

    // アクティブセクションのハイライト
    function updateActiveTocLink() {
      let currentActiveId = '';

      // 現在見えている見出しを特定
      for (const heading of headings) {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= 100) {
          currentActiveId = heading.id;
        }
      }

      // 全てのリンクからactiveクラスを削除
      tocLinks.forEach(link => link.classList.remove('active'));

      // 現在のセクションのリンクにactiveクラスを追加
      if (currentActiveId) {
        const activeLink = document.querySelector(`a[href="#${currentActiveId}"]`);
        if (activeLink) {
          activeLink.classList.add('active');
        }
      }
    }

    // スクロール時にアクティブセクションを更新
    window.addEventListener('scroll', updateActiveTocLink);
    updateActiveTocLink(); // 初期化

    // ウィンドウリサイズ時の対応
    window.addEventListener('resize', () => {
      const newIsMobile = window.innerWidth <= 768;
      if (newIsMobile && !isCollapsed && tocDetails.open) {
        // デスクトップからモバイルに変わった時、展開されていれば折り畳む
        tocDetails.removeAttribute('open');
      }
    });
  });
</script>

<style>
  .toc-link.active,
  .toc-sublink.active {
    color: var(--accent);
    background: var(--active-background);
    padding-left: 0.5rem;
    font-weight: 700;
  }
</style>
