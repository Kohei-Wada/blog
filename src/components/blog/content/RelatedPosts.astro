---
import type { CollectionEntry } from 'astro:content';
import PostsList from './PostsList.astro';

export interface Props {
  posts: CollectionEntry<'blog'>[];
  currentTags?: string[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="man-section related-posts">
      <h2>SEE ALSO</h2>
      <PostsList posts={posts} />
    </section>
  )
}

<style>
  .related-posts {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }

  .related-posts h2 {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    color: var(--color-text);
  }

  /* モバイル対応 */
  @media (max-width: 768px) {
    .related-posts {
      margin-top: 3rem;
      padding-top: 1.5rem;
    }

    .related-posts h2 {
      font-size: 1.3rem;
      margin-bottom: 1.25rem;
    }
  }

  /* 小型モバイル対応 */
  @media (max-width: 480px) {
    .related-posts {
      margin-top: 2.5rem;
    }

    .related-posts h2 {
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }
  }
</style>
