---
import FormattedDate from '../../shared/ui/FormattedDate.astro';
import CalendarIcon from '../../shared/icons/CalendarIcon.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
  currentTag?: string;
}

const { post, currentTag } = Astro.props;
---

<article class="post-card">
  <a href={`/blog/${post.id}/`}>
    <div class="post-content">
      <div class="post-main">
        <h2>{post.data.title}</h2>
        {post.data.description && <p class="post-description">{post.data.description}</p>}
      </div>
      <div class="post-aside">
        <div class="post-meta">
          <CalendarIcon />
          <FormattedDate date={post.data.pubDate} />
          {post.data.featured && <span class="featured-badge">おすすめ</span>}
        </div>
        <div class="post-tags tag-list">
          {
            post.data.tags.map((tag: string) => (
              <span class={`tag ${tag === currentTag ? 'current' : ''}`}>{tag}</span>
            ))
          }
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--card-background);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
    border: var(--card-border);
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--color-link);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-content {
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    min-height: 4.5rem;
  }

  .post-main {
    flex: 1;
    min-width: 0;
  }

  .post-aside {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .post-meta {
    color: var(--color-link);
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .featured-badge {
    background: var(--color-link);
    color: var(--color-bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .post-card h2 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    color: var(--color-text);
  }

  .post-description {
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
  }

  /* Responsive - タブレット以下で縦積みに */
  @media (max-width: 768px) {
    .post-content {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .post-aside {
      align-items: flex-start;
      flex-direction: row;
      justify-content: space-between;
      width: 100%;
    }

    .post-tags {
      justify-content: flex-start;
    }

    .post-description {
      -webkit-line-clamp: 2;
    }
  }

  @media (max-width: 480px) {
    .post-content {
      padding: 0.75rem;
    }

    .post-card h2 {
      font-size: 1rem;
    }

    .post-description {
      font-size: 0.85rem;
    }

    .post-meta {
      font-size: 0.8rem;
    }
  }
</style>
