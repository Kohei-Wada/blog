---
import FormattedDate from '../../shared/ui/FormattedDate.astro';
import CalendarIcon from '../../shared/icons/CalendarIcon.astro';
import type { CollectionEntry } from 'astro:content';
import { getBlogPostUrl } from '../../../utils/url-builders';

export interface Props {
  post: CollectionEntry<'blog'>;
  currentTag?: string;
}

const { post, currentTag } = Astro.props;
---

<article class="post-card">
  <a href={getBlogPostUrl(post.id)}>
    <div class="post-content">
      <div class="post-main">
        <h2>{post.data.title}</h2>
        {post.data.description && <p class="post-description">{post.data.description}</p>}
        <div class="post-footer">
          <div class="post-meta">
            <CalendarIcon />
            <FormattedDate date={post.data.pubDate} />
          </div>
          <div class="post-tags tag-list">
            {post.data.featured && <span class="tag featured">おすすめ</span>}
            {
              post.data.tags.map((tag: string) => (
                <span class={`tag ${tag === currentTag ? 'current' : ''}`}>{tag}</span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--card-background);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
    border: var(--card-border);
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--color-link);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-content {
    padding: 1.25rem 1.5rem;
  }

  .post-main {
    display: flex;
    flex-direction: column;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .post-meta {
    color: var(--color-link);
    font-size: 0.85rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tag.featured {
    background: var(--color-link);
    color: var(--color-bg);
  }

  .post-card h2 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    height: calc(1.1rem * 1.4 * 2); /* 2行分の高さを固定 */
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-description {
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
  }

  /* Responsive - タブレット以下 */
  @media (max-width: 768px) {
    .post-content {
      padding: 1rem;
    }

    .post-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .post-tags {
      justify-content: flex-start;
    }

    .post-description {
      -webkit-line-clamp: 2;
    }
  }

  @media (max-width: 480px) {
    .post-content {
      padding: 0.75rem;
    }

    .post-card h2 {
      font-size: 1rem;
      height: calc(1rem * 1.4 * 2);
    }

    .post-description {
      font-size: 0.85rem;
    }

    .post-meta {
      font-size: 0.8rem;
    }
  }
</style>
