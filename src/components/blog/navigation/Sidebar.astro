---
import { getCollection } from 'astro:content';
import GitHubActivity from '../../integrations/GitHubActivity.astro';
import { groupPostsByMonth, getRecentArchiveMonths } from '../../../utils/archive-utils';
import { getAllTags, getTagCounts } from '../../../utils/content-aggregation';
import { getTagUrl, getArchiveUrl } from '../../../utils/url-builders';

const allPosts = await getCollection('blog');
const allTags = getAllTags(allPosts);
const tagCounts = getTagCounts(allPosts);

// Get monthly archives
const allArchives = groupPostsByMonth(allPosts);
const recentArchives = getRecentArchiveMonths(allArchives, 6);
---

<aside class="sidebar">
  <section class="sidebar-section">
    <h3><a href="/archives/">月別アーカイブ</a></h3>
    {
      recentArchives.length > 0 ? (
        <ul class="archive-list list-reset">
          {recentArchives.map(archive => (
            <li class="list-item">
              <a href={getArchiveUrl(archive.year, archive.month)}>
                <span class="archive-month">{archive.label}</span>
                <span class="archive-count">({archive.count})</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p style="color: var(--color-text-secondary); font-size: 0.9em;">
          まだ記事が投稿されていません。
        </p>
      )
    }
  </section>

  <section class="sidebar-section">
    <h3>タグ</h3>
    <div class="tag-cloud tag-list">
      {
        allTags.map(tag => (
          <a href={getTagUrl(tag)} class="tag solid" data-count={tagCounts[tag]}>
            {tag} ({tagCounts[tag]})
          </a>
        ))
      }
    </div>
  </section>

  <GitHubActivity />
</aside>

<style>
  .sidebar {
    width: 100%;
    padding: 1rem 1rem 0 1rem;
    margin-top: 1rem;
  }

  .sidebar-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--card-background);
    border-radius: 8px;
  }

  .sidebar-section h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2em;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-link);
    padding-bottom: 0.5rem;
  }

  .sidebar-section h3 a {
    color: inherit;
    text-decoration: none;
  }

  .sidebar-section h3 a:hover {
    color: var(--color-link);
  }

  .archive-list a {
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.25rem 0;
    transition: color var(--transition-normal);
  }

  .archive-list a:hover {
    color: var(--color-link);
  }

  .archive-month {
    font-size: 0.9em;
    font-weight: 500;
  }

  .archive-count {
    font-size: 0.8em;
    color: var(--color-text-secondary);
    font-weight: normal;
  }

  .archive-list a:hover .archive-count {
    color: var(--color-link);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
