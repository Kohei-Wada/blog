---
import type { MarkdownHeading, TocItem } from '../../../types/index.js';
import { buildTocStructure } from '../../../utils/toc-builder.js';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const tocStructure = buildTocStructure(headings);

// TOCが表示すべき見出しがあるかチェック
const hasToc = tocStructure.length > 0;
---

{
  hasToc && (
    <nav class="table-of-contents">
      <details class="toc-details">
        <summary class="toc-summary" role="button" aria-label="目次の表示/非表示を切り替え">
          <span class="toc-title">目次</span>
          <span class="toc-toggle" aria-hidden="true">
            ▼
          </span>
        </summary>
        <ol class="toc-list">
          {tocStructure.map(item => (
            <li>
              <a href={`#${item.slug}`} class="toc-link">
                {item.text}
              </a>
              {item.subheadings.length > 0 && (
                <ol class="toc-sublist">
                  {item.subheadings.map((subItem: TocItem) => (
                    <li>
                      <a href={`#${subItem.slug}`} class="toc-sublink">
                        {subItem.text}
                      </a>
                    </li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </details>
    </nav>
  )
}

<style>
  .table-of-contents {
    background: var(--card-background);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: var(--card-border);
  }

  .toc-details {
    border: none;
    margin: 0;
    padding: 0;
  }

  .toc-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 1rem 0;
    padding: 0.75rem 0 0.5rem 0;
    border-bottom: 2px solid var(--color-link);
    transition: all 0.2s ease;
    user-select: none;
    outline: none;
  }

  .toc-summary:hover {
    color: var(--color-link);
  }

  .toc-summary::-webkit-details-marker {
    display: none;
  }

  .toc-title {
    font-size: 1.1em;
    color: var(--color-text);
    font-weight: 600;
  }

  .toc-toggle {
    font-size: 0.9em;
    color: var(--color-link);
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .toc-details:not([open]) .toc-toggle {
    transform: rotate(-90deg);
  }

  .toc-details[open] .toc-toggle {
    transform: rotate(0deg);
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: toc-counter;
  }

  .toc-list > li {
    counter-increment: toc-counter;
    margin-bottom: 0.75rem;
  }

  .toc-list > li:last-child {
    margin-bottom: 0;
  }

  .toc-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95em;
    line-height: 1.4;
    display: block;
    padding: 0.25rem 0;
    border-radius: 4px;
    transition: all 0.2s ease;
    position: relative;
  }

  .toc-link::before {
    content: counter(toc-counter) '. ';
    color: var(--color-link);
    font-weight: 700;
  }

  .toc-link:hover {
    color: var(--color-link);
    background: var(--active-background);
    padding-left: 0.5rem;
  }

  .toc-sublist {
    margin: 0.5rem 0 0 1.5rem;
    padding: 0;
    list-style: none;
    border-left: 2px solid var(--color-border);
    padding-left: 1rem;
  }

  .toc-sublist li {
    margin-bottom: 0.5rem;
  }

  .toc-sublist li:last-child {
    margin-bottom: 0;
  }

  .toc-sublink {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9em;
    line-height: 1.3;
    display: block;
    padding: 0.2rem 0;
    transition: all 0.2s ease;
    position: relative;
  }

  .toc-sublink::before {
    content: '• ';
    color: var(--color-link);
    font-weight: bold;
    margin-right: 0.25rem;
  }

  .toc-sublink:hover {
    color: var(--color-link);
    padding-left: 0.5rem;
  }

  /* モバイル対応 */
  @media (max-width: 768px) {
    .table-of-contents {
      margin: 1rem 0 2rem 0;
      padding: 1.25rem;
    }

    .toc-link {
      font-size: 0.9em;
    }

    .toc-sublink {
      font-size: 0.85em;
    }

    .toc-sublist {
      margin-left: 1rem;
      padding-left: 0.75rem;
    }
  }

  /* スムーズスクロール */
  html {
    scroll-behavior: smooth;
  }

  /* アンカーリンクのオフセット調整 */
  :target {
    scroll-margin-top: 2rem;
  }
</style>

<script>
  import {
    TocStateManager,
    isMobileViewport,
    shouldCollapseOnInit,
    findActiveHeadingId,
    updateTocLinkActiveState,
  } from '../../../utils/toc-controller';

  // TOC initialization
  document.addEventListener('DOMContentLoaded', () => {
    const tocDetails = document.querySelector('.toc-details') as HTMLDetailsElement;
    const tocLinks = document.querySelectorAll('.toc-link, .toc-sublink');
    const headings = document.querySelectorAll('h2[id], h3[id]');

    if (!tocDetails) return;

    // Open TOC if user hasn't collapsed it and not on mobile
    if (!shouldCollapseOnInit()) {
      tocDetails.setAttribute('open', '');
    }

    // Save collapsed state on toggle
    tocDetails.addEventListener('toggle', () => {
      TocStateManager.setCollapsedState(!tocDetails.open);
    });

    // Update active section highlight
    function updateActiveTocLink() {
      const activeId = findActiveHeadingId(headings);
      updateTocLinkActiveState(tocLinks, activeId);
    }

    // Scroll listener
    window.addEventListener('scroll', updateActiveTocLink);
    updateActiveTocLink();

    // Responsive collapse on resize
    window.addEventListener('resize', () => {
      if (isMobileViewport() && !initialCollapsed && tocDetails.open) {
        tocDetails.removeAttribute('open');
      }
    });
  });
</script>

<style>
  .toc-link.active,
  .toc-sublink.active {
    color: var(--accent);
    background: var(--active-background);
    padding-left: 0.5rem;
    font-weight: 700;
  }
</style>
