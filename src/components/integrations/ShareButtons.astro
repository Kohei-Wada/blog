---
import { SOCIAL_SHARE_URLS } from '../../constants/api.js';
import Icon from '../shared/icons/Icon.astro';

interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;

// Encoded parameters for share URLs
const encodedUrl = encodeURIComponent(url);
const encodedText = encodeURIComponent(`${title} - ${description}`);

// Share URLs
const twitterUrl = `${SOCIAL_SHARE_URLS.TWITTER}?text=${encodedText}&url=${encodedUrl}`;
const facebookUrl = `${SOCIAL_SHARE_URLS.FACEBOOK}?u=${encodedUrl}`;
const lineUrl = `${SOCIAL_SHARE_URLS.LINE}?url=${encodedUrl}&text=${encodedText}`;
const linkedinUrl = `${SOCIAL_SHARE_URLS.LINKEDIN}?url=${encodedUrl}`;
---

<div class="share-buttons">
  <h3>Share this post</h3>
  <div class="buttons">
    <a href={twitterUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter">
      <Icon name="x" width={20} height={20} />
      Twitter
    </a>
    <a href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
      <Icon name="facebook" width={20} height={20} />
      Facebook
    </a>
    <a href={lineUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on LINE">
      <Icon name="line" width={20} height={20} />
      LINE
    </a>
    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
      <Icon name="linkedin" width={20} height={20} />
      LinkedIn
    </a>
  </div>
</div>

<style>
  .share-buttons {
    margin: var(--spacing-md) 0;
    padding: var(--spacing-md);
    border-top: var(--separator-border);
    text-align: center;
  }

  .share-buttons h3 {
    margin: 0 0 var(--spacing-sm) 0;
    font-size: var(--font-size-xl);
    color: var(--color-text);
  }

  .buttons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .buttons a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin: 0 var(--spacing-xs) var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--subtle-background);
    color: var(--accent);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-normal);
    font-size: var(--font-size-base);
    border: 1px solid transparent;
  }

  .buttons a:hover {
    background-color: var(--accent);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
    border-color: var(--accent);
  }

  .buttons a:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    background-color: var(--active-background);
  }

  .buttons svg {
    flex-shrink: 0;
  }

  @media (max-width: var(--mobile-breakpoint)) {
    .buttons {
      flex-direction: column;
      align-items: center;
    }

    .buttons a {
      width: 100%;
      max-width: 200px;
      justify-content: center;
    }
  }
</style>
