---
import type { GitHubEvent } from '../../schemas/github.js';
import { formatRelativeDate } from '../../utils/github-api.js';
import { GITHUB_ACTIVITY_CONFIG } from '../../constants/api.js';

interface Props {
  events: GitHubEvent[];
}

const { events } = Astro.props;

// Filter events and get recent commits
const recentCommits = events
  .filter(event => event.type === 'PushEvent')
  .slice(0, GITHUB_ACTIVITY_CONFIG.MAX_RECENT_COMMITS)
  .flatMap(event =>
    (event.payload.commits || []).slice(0, 1).map(commit => ({
      repo: event.repo.name,
      message: commit.message.split('\n')[0], // First line only
      date: new Date(event.created_at),
    }))
  );
---

{
  recentCommits.length > 0 && (
    <div class="github-section">
      <h4>最近のコミット</h4>
      <ul class="commit-list list-reset">
        {recentCommits.map(commit => (
          <li class="list-item-lg">
            <div class="commit-repo">{commit.repo.split('/')[1]}</div>
            <div class="commit-message">{commit.message}</div>
            <div class="commit-date">{formatRelativeDate(commit.date)}</div>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .commit-repo {
    font-size: 0.9em;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .commit-message {
    font-size: 0.9em;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .commit-date {
    font-size: 0.8em;
    color: var(--color-text-secondary);
  }
</style>
