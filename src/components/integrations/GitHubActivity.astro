---
import type { GitHubEvent, GitHubRepo, GlobalThisWithStats } from '../../types/index.js';
import { fetchGitHubData } from '../../utils/github-api.js';
import { logGitHubApiStats } from '../../utils/build-stats.js';
import GitHubIcon from './GitHubIcon.astro';
import GitHubRecentCommits from './GitHubRecentCommits.astro';
import GitHubActiveRepos from './GitHubActiveRepos.astro';

// Safely execute data fetching
let events: GitHubEvent[] = [];
let repos: GitHubRepo[] = [];

try {
  const data = await fetchGitHubData();
  events = data.events;
  repos = data.repos;

  // Output build statistics (except in development)
  if (import.meta.env.PUBLIC_DISABLE_GITHUB_API !== 'true') {
    // Output global statistics in cleanup process
    const globalStats = globalThis as unknown as GlobalThisWithStats;
    if (typeof globalThis !== 'undefined' && !globalStats._githubStatsLogged) {
      globalStats._githubStatsLogged = true;
      // Display statistics on process exit
      process?.on?.('exit', logGitHubApiStats);
    }
  }
} catch (error) {
  console.error('Critical error in GitHubActivity component:', error);
  // Continue with empty data so component doesn't crash on error
}
---

<section class="sidebar-section github-activity">
  <h3>
    <GitHubIcon class="github-icon" width={16} height={16} />
    GitHub Activity
  </h3>

  <GitHubRecentCommits events={events} />
  <GitHubActiveRepos repos={repos} />

  <div class="github-link">
    <a href="https://github.com/Kohei-Wada" target="_blank" rel="noopener noreferrer">
      View on GitHub →
    </a>
  </div>
</section>

<style>
  /* Inherit existing sidebar section styles */
  .github-activity {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--card-background);
    border-radius: 8px;
  }

  .github-activity h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2em;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-link);
    padding-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .github-icon {
    width: 18px;
    height: 18px;
  }

  .github-link {
    text-align: center;
    padding-top: 0.75rem;
    margin-top: 0.5rem;
    border-top: var(--separator-border);
  }

  .github-link a {
    font-size: 0.85em;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: all 0.2s ease;
  }

  .github-link a:hover {
    gap: 0.5rem;
    text-decoration: underline;
  }
</style>
