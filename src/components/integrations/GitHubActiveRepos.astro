---
import type { GitHubRepo } from '../../types/index.js';
import { GITHUB_ACTIVITY_CONFIG } from '../../constants/api.js';

interface Props {
  repos: GitHubRepo[];
}

const { repos } = Astro.props;

// アクティブなリポジトリ
const activeRepos = repos.slice(0, GITHUB_ACTIVITY_CONFIG.MAX_ACTIVE_REPOS);
---

{
  activeRepos.length > 0 && (
    <div class="github-section">
      <h4>アクティブなリポジトリ</h4>
      <ul class="repo-list list-reset">
        {activeRepos.map(repo => (
          <li>
            <a href={repo.html_url} target="_blank" rel="noopener noreferrer">
              <div class="repo-name">{repo.name}</div>
              <div class="repo-meta">
                {repo.language && <span class="repo-lang">{repo.language}</span>}
                <span class="repo-stars">⭐ {repo.stargazers_count}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .github-section {
    margin-bottom: 1.25rem;
  }

  .github-section:last-of-type {
    margin-bottom: 1rem;
  }

  .github-section h4 {
    font-size: 0.95em;
    margin: 0 0 0.75rem 0;
    color: var(--color-text);
    font-weight: 600;
  }

  .repo-list li {
    margin-bottom: 0.75rem;
  }

  .repo-list li:last-child {
    margin-bottom: 0;
  }

  .repo-list a {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 0.5rem 0.75rem;
    background: var(--subtle-background);
    border: var(--card-border);
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .repo-list a:hover {
    background: var(--hover-background);
    border-color: var(--accent);
    color: var(--accent);
  }

  .repo-name {
    font-size: 0.9em;
    font-weight: 600;
    color: inherit;
    margin-bottom: 0.25rem;
  }

  .repo-meta {
    font-size: 0.8em;
    color: var(--color-text-secondary);
    display: flex;
    gap: 1rem;
  }

  .repo-lang {
    display: inline-flex;
    align-items: center;
  }

  .repo-lang::before {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 0.25rem;
  }
</style>
