---
/**
 * GitHub Icon (wrapper for backward compatibility)
 */
import Icon from '../shared/icons/Icon.astro';

interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 32, height = 32, class: className = '' } = Astro.props;
---

<Icon name="github" width={width} height={height} class={className} />
