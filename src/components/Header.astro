---
import HeaderLink from './HeaderLink.astro';
import GitHubIcon from './GitHubIcon.astro';
import { SITE_TITLE, GITHUB_URL } from '../consts';
---

<header>
  <nav aria-label="Main navigation">
    <div class="nav-left">
      <h2><a href="/">{SITE_TITLE}</a></h2>
    </div>
    <div class="nav-center">
      <HeaderLink href="/">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 9l9-7 9 7v11a2 2 0 01-2 2h-4a2 2 0 01-2-2V12H9v8a2 2 0 01-2 2H3a2 2 0 01-2-2z"
          ></path>
        </svg>
        Home
      </HeaderLink>
      <HeaderLink href="/blog">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-7-7l7 7-7 7-7-7 7-7z"></path>
        </svg>
        Blog
      </HeaderLink>
      <HeaderLink href="/tags">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 7l10 10 4-4V7a2 2 0 00-2-2H9a2 2 0 00-2 2z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9h.01"></path>
        </svg>
        Tags
      </HeaderLink>
      <HeaderLink href="/about">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5.121 17.804A9 9 0 1118.88 6.196 9 9 0 015.12 17.804z"></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        About
      </HeaderLink>
      <HeaderLink href="/contact">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="nav-icon"
          aria-hidden="true"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 8h18a2 2 0 002-2V8a2 2 0 00-2-2H3a2 2 0 00-2 2v6a2 2 0 002 2z"
          ></path>
        </svg>
        Contact
      </HeaderLink>
    </div>
    <div class="nav-right">
      <a href={GITHUB_URL} target="_blank" aria-label="Visit GitHub profile (opens in new tab)">
        <GitHubIcon />
      </a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    width: 100%;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }

  nav {
    width: 100%;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-left {
    display: flex;
    align-items: center;
  }

  .nav-center {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-right {
    display: flex;
    align-items: center;
  }

  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav a {
    display: inline-flex;
    align-items: center;
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .nav-right,
  .nav-right a {
    display: flex;
  }
  .nav-icon {
    width: 1em;
    height: 1em;
    margin-right: 0.25em;
  }
  @media (max-width: var(--tablet-breakpoint)) {
    nav {
      padding: 0 var(--spacing-xs);
    }

    .nav-right {
      display: none;
    }
  }
</style>
