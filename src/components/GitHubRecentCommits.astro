---
import type { GitHubEvent } from '../types/index.js';
import { formatRelativeDate } from '../utils/github-api.js';
import { GITHUB_ACTIVITY_CONFIG } from '../constants/api.js';

interface Props {
  events: GitHubEvent[];
}

const { events } = Astro.props;

// イベントをフィルタリングして最新コミットを取得
const recentCommits = events
  .filter(event => event.type === 'PushEvent')
  .slice(0, GITHUB_ACTIVITY_CONFIG.MAX_RECENT_COMMITS)
  .flatMap(event =>
    (event.payload.commits || []).slice(0, 1).map(commit => ({
      repo: event.repo.name,
      message: commit.message.split('\n')[0], // 最初の行のみ
      date: new Date(event.created_at),
    }))
  );
---

{
  recentCommits.length > 0 && (
    <div class="github-section">
      <h4>最近のコミット</h4>
      <ul class="commit-list">
        {recentCommits.map(commit => (
          <li>
            <div class="commit-repo">{commit.repo.split('/')[1]}</div>
            <div class="commit-message">{commit.message}</div>
            <div class="commit-date">{formatRelativeDate(commit.date)}</div>
          </li>
        ))}
      </ul>
    </div>
  )
}

<style>
  .github-section {
    margin-bottom: 1.25rem;
  }

  .github-section:last-of-type {
    margin-bottom: 1rem;
  }

  .github-section h4 {
    font-size: 0.95em;
    margin: 0 0 0.75rem 0;
    color: var(--color-text);
    font-weight: 600;
  }

  .commit-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .commit-list li {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: var(--separator-border);
  }

  .commit-list li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .commit-repo {
    font-size: 0.9em;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .commit-message {
    font-size: 0.9em;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .commit-date {
    font-size: 0.8em;
    color: var(--color-text-secondary);
  }
</style>
