---
import FormattedDate from './FormattedDate.astro';
import { Image } from 'astro:assets';

export interface Props {
  post: any;
  currentTag?: string;
}

const { post, currentTag } = Astro.props;
---

<article class="post-card">
  <a href={`/blog/${post.id}/`}>
    {
      post.data.heroImage && (
        <Image
          src={post.data.heroImage}
          alt={post.data.title}
          width={400}
          height={200}
          class="post-image"
        />
      )
    }
    <div class="post-content">
      <div class="post-meta">
        <FormattedDate date={post.data.pubDate} />
        {post.data.featured && <span class="featured-badge">おすすめ</span>}
      </div>
      <h2>{post.data.title}</h2>
      <p class="post-description">{post.data.description}</p>
      <div class="post-tags tag-list">
        {
          post.data.tags.map((tag: string) => (
            <span class={`tag ${tag === currentTag ? 'current' : ''}`}>{tag}</span>
          ))
        }
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--card-background);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    border: var(--card-border);
    max-height: 400px;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-link);
  }

  .post-card a {
    text-decoration: none;
    color: inherit;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .post-image {
    width: 100%;
    height: 150px;
    object-fit: cover;
    display: block;
  }

  .post-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-meta {
    color: var(--color-link);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .featured-badge {
    background: var(--color-link);
    color: var(--color-bg);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .post-card h2 {
    font-size: 1.2rem;
    margin: 0 0 0.8rem;
    line-height: 1.3;
    color: var(--color-text);
    flex-grow: 1;
  }

  .post-description {
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.9rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  /* Responsive */
  @media (max-width: 1024px) and (min-width: 769px) {
    .post-content {
      padding: 1.25rem;
    }

    .post-card h2 {
      font-size: 1.15rem;
    }

    .post-description {
      font-size: 0.88rem;
    }
  }

  @media (max-width: 768px) {
    .post-content {
      padding: 1rem;
    }

    .post-image {
      height: 120px;
    }

    .post-card {
      max-height: 320px;
    }

    .post-card h2 {
      font-size: 1.1rem;
      margin-bottom: 0.6rem;
    }

    .post-description {
      font-size: 0.85rem;
      margin-bottom: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .post-content {
      padding: 0.75rem;
    }

    .post-image {
      height: 100px;
    }

    .post-card {
      max-height: 280px;
    }

    .post-card h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .post-description {
      font-size: 0.8rem;
      margin-bottom: 0.6rem;
      -webkit-line-clamp: 2;
    }

    .post-meta {
      font-size: 0.8rem;
      margin-bottom: 0.75rem;
    }
  }
</style>
