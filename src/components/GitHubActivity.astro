---
import type { GitHubEvent, GitHubRepo } from '../types/index.js';
import { fetchGitHubData } from '../utils/github-api.js';
import GitHubIcon from './GitHubIcon.astro';
import GitHubRecentCommits from './GitHubRecentCommits.astro';
import GitHubActiveRepos from './GitHubActiveRepos.astro';

// データ取得を安全に実行
let events: GitHubEvent[] = [];
let repos: GitHubRepo[] = [];

try {
  const data = await fetchGitHubData();
  events = data.events;
  repos = data.repos;
} catch (error) {
  console.error('Critical error in GitHubActivity component:', error);
  // エラーが発生してもコンポーネント全体がクラッシュしないよう空のデータで継続
}
---

<section class="sidebar-section github-activity">
  <h3>
    <GitHubIcon class="github-icon" width={16} height={16} />
    GitHub Activity
  </h3>

  <GitHubRecentCommits events={events} />
  <GitHubActiveRepos repos={repos} />

  <div class="github-link">
    <a href="https://github.com/Kohei-Wada" target="_blank" rel="noopener noreferrer">
      View on GitHub →
    </a>
  </div>
</section>

<style>
  /* 既存のサイドバーセクションスタイルを継承 */
  .github-activity {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--card-background);
    border-radius: 8px;
  }

  .github-activity h3 {
    margin: 0 0 1rem 0;
    font-size: 1.2em;
    color: rgb(var(--black));
    border-bottom: 2px solid var(--accent);
    padding-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .github-icon {
    width: 18px;
    height: 18px;
  }

  .github-link {
    text-align: center;
    padding-top: 0.75rem;
    margin-top: 0.5rem;
    border-top: var(--separator-border);
  }

  .github-link a {
    font-size: 0.85em;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: all 0.2s ease;
  }

  .github-link a:hover {
    gap: 0.5rem;
    text-decoration: underline;
  }
</style>
